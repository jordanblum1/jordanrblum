---
import type { RowItem } from '../data/site';

interface Props {
  item: RowItem;
  index: number;
}

const { item, index } = Astro.props;
const Tag = item.href ? 'a' : 'article';
---

<Tag
  class="row reveal"
  data-row={index}
  href={item.href}
  target={item.href ? '_blank' : undefined}
  rel={item.href ? 'noopener' : undefined}
>
  <div class="row-heading">
    <h3>{item.title}</h3>
    <span class="date mono-meta">{item.date}</span>
  </div>
  <p class="meta mono-meta">{item.meta}</p>
  <p class="blurb">{item.blurb}</p>
</Tag>

<style>
  .row {
    display: grid;
    grid-template-columns: minmax(11rem, 0.45fr) 1fr;
    column-gap: var(--space-8);
    padding-block: var(--space-6);
    border-top: 1px solid var(--hairline);
    transition: background var(--duration-default) var(--ease), padding-inline var(--duration-default) var(--ease);
  }

  .row:last-child {
    border-bottom: 1px solid var(--hairline);
  }

  html.pointer-moved .row:hover {
    padding-inline: var(--space-3);
    background: var(--hover-fill);
  }

  .row-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
  }

  h3 {
    font-size: 1rem;
  }

  .meta {
    grid-column: 1;
    margin-top: var(--space-1);
  }

  .blurb {
    grid-column: 2;
    grid-row: 1 / span 2;
    max-width: 48ch;
    color: var(--ink-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    text-wrap: pretty;
  }

  @media (max-width: 40rem) {
    .row {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .meta,
    .blurb {
      grid-column: 1;
      grid-row: auto;
    }

    html.pointer-moved .row:hover {
      padding-inline: 0;
    }
  }
</style>
