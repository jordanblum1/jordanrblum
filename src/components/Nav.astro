---
import { Image } from 'astro:assets';
import jrbBlue from '../assets/identity/jrb-logo-blue.png';
import jrbRed from '../assets/identity/jrb-logo-red.png';

const onHome = Astro.url.pathname === '/';
const onAbout = Astro.url.pathname.startsWith('/about');
const workHref = onHome ? '#work' : '/#work';
---

<nav class="nav-shell" aria-label="Primary">
  <div class="nav-pill" data-nav-pill>
    <a class="wordmark" href="/" aria-label="Jordan Blum — home" aria-current={onHome ? 'page' : undefined}>
      <span class="mark-stack" data-nav-mark aria-hidden="true">
        <Image class="mark-image mark-red" src={jrbRed} alt="" width={56} height={56} loading="eager" />
        <Image class="mark-image mark-blue" src={jrbBlue} alt="" width={56} height={56} loading="eager" />
      </span>
      <span class="visually-hidden">Jordan Blum</span>
    </a>

    <div class="nav-links">
      <a href={workHref}>
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none">
            <rect x="3" y="5.5" width="14" height="10.5" rx="2.5" stroke="currentColor" stroke-width="1.5" />
            <path d="M7 5.5V4.75C7 3.78 7.78 3 8.75 3h2.5C12.22 3 13 3.78 13 4.75v.75M3.5 9.25h13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
        </span>
        <span class="nav-label">Work</span>
      </a>
      <a href="/about" aria-current={onAbout ? 'page' : undefined}>
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none">
            <circle cx="10" cy="7" r="3" stroke="currentColor" stroke-width="1.5" />
            <path d="M4.5 16c.55-3.1 2.38-4.65 5.5-4.65S14.95 12.9 15.5 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
        </span>
        <span class="nav-label">About</span>
      </a>
      <a href="mailto:jordanblum16@gmail.com">
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none">
            <rect x="2.75" y="4.5" width="14.5" height="11" rx="2.5" stroke="currentColor" stroke-width="1.5" />
            <path d="m4 6 6 4.25L16 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <span class="nav-label">Email</span>
      </a>
    </div>
  </div>
</nav>

<script>
  const navPill = document.querySelector<HTMLElement>('[data-nav-pill]');
  const navMark = document.querySelector<HTMLElement>('[data-nav-mark]');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (navPill && navMark && !reducedMotion.matches) {
    type MotionMode = 'idle' | 'winding' | 'releasing';

    let settleTimer = 0;
    let lastScrollY = window.scrollY;
    let lastDirection = 1;
    let mode: MotionMode = 'idle';
    let currentAngle = 0;
    let targetAngle = 0;
    let gestureAnchor = 0;
    let gestureDistance = 0;
    let windFrame = 0;
    let lastWindFrameAt = 0;
    let releaseFrame = 0;

    const renderAngle = (angle: number) => {
      currentAngle = angle;
      navMark.style.setProperty('--mark-wind', `${angle}deg`);
    };

    const freezeRelease = () => {
      if (!releaseFrame) return;
      window.cancelAnimationFrame(releaseFrame);
      releaseFrame = 0;
      targetAngle = currentAngle;
      mode = 'idle';
      delete navMark.dataset.releasing;
    };

    const wind = (now: number) => {
      const elapsed = lastWindFrameAt ? Math.min(48, now - lastWindFrameAt) : 16.7;
      lastWindFrameAt = now;
      const distance = targetAngle - currentAngle;
      const smoothing = 1 - Math.exp(-elapsed / 70);
      renderAngle(currentAngle + distance * smoothing);

      if (Math.abs(distance) > 0.08) {
        windFrame = window.requestAnimationFrame(wind);
      } else {
        renderAngle(targetAngle);
        windFrame = 0;
        lastWindFrameAt = 0;
      }
    };

    const release = () => {
      delete navPill.dataset.scrolling;
      if (mode !== 'winding') return;

      if (windFrame) {
        window.cancelAnimationFrame(windFrame);
        windFrame = 0;
        lastWindFrameAt = 0;
      }

      const startAngle = currentAngle;
      const direction = lastDirection || 1;
      const nextUpright = direction > 0
        ? Math.ceil(startAngle / 360) * 360
        : Math.floor(startAngle / 360) * 360;
      // Always include two full release turns; the fractional remainder lands upright.
      const endAngle = nextUpright + direction * 720;
      const distance = endAngle - startAngle;
      const duration = 1500;
      const startedAt = performance.now();

      mode = 'releasing';
      navMark.dataset.releasing = '';
      const tick = (now: number) => {
        const progress = Math.min(1, (now - startedAt) / duration);
        const eased = 1 - (1 - progress) ** 3;
        renderAngle(startAngle + distance * eased);

        if (progress < 1) {
          releaseFrame = window.requestAnimationFrame(tick);
          return;
        }

        renderAngle(0);
        targetAngle = 0;
        gestureAnchor = 0;
        gestureDistance = 0;
        releaseFrame = 0;
        mode = 'idle';
        delete navMark.dataset.releasing;
      };

      releaseFrame = window.requestAnimationFrame(tick);
    };

    const markScrolling = () => {
      const nextScrollY = window.scrollY;
      const delta = nextScrollY - lastScrollY;
      lastScrollY = nextScrollY;

      if (Math.abs(delta) < 0.75) return;

      freezeRelease();

      const direction = Math.sign(delta);
      if (mode !== 'winding' || direction !== lastDirection) {
        mode = 'winding';
        gestureAnchor = currentAngle;
        gestureDistance = 0;
        targetAngle = currentAngle;
      }

      lastDirection = direction;
      // Deliberately unbounded: a continuous scroll can keep winding forever.
      gestureDistance += Math.abs(delta);
      targetAngle = gestureAnchor + direction * gestureDistance * 0.32;
      if (!windFrame) windFrame = window.requestAnimationFrame(wind);

      navPill.dataset.scrolling = '';
      window.clearTimeout(settleTimer);
      settleTimer = window.setTimeout(release, 240);
    };

    window.addEventListener('scroll', markScrolling, { passive: true });
  }
</script>

<style>
  .nav-shell {
    position: sticky;
    top: var(--space-2);
    z-index: 40;
    display: grid;
    width: min(100% - var(--space-4), var(--wide));
    height: 2.4rem;
    place-items: start center;
    margin: var(--space-2) auto 0;
    pointer-events: none;
  }

  .nav-pill {
    display: grid;
    grid-template-columns: auto auto;
    justify-content: space-between;
    gap: var(--space-4);
    align-items: center;
    width: min(100%, 20.5rem);
    min-height: 2.4rem;
    margin-inline: 0;
    padding: var(--space-1) 0.35rem var(--space-1) var(--space-2);
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--hairline) 82%, transparent);
    border-radius: var(--radius-pill);
    background: color-mix(in oklab, var(--surface-raised) 88%, transparent);
    box-shadow: var(--shadow-small);
    backdrop-filter: blur(var(--space-3));
    pointer-events: auto;
    transform: translateZ(0);
    transform-origin: 50% 0;
    transition:
      width 620ms cubic-bezier(0.34, 1.35, 0.64, 1),
      min-height 620ms cubic-bezier(0.34, 1.35, 0.64, 1),
      padding 620ms cubic-bezier(0.34, 1.35, 0.64, 1),
      gap 620ms cubic-bezier(0.34, 1.35, 0.64, 1),
      transform 620ms cubic-bezier(0.34, 1.35, 0.64, 1),
      box-shadow var(--duration-default) var(--ease);
  }

  .nav-pill[data-scrolling] {
    width: 8.75rem;
    min-height: 1.9rem;
    gap: var(--space-1);
    padding: 0.18rem 0.3rem;
    transform: translateY(-1px);
    transition-duration: 160ms;
    transition-timing-function: var(--ease);
  }

  .wordmark,
  .nav-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.85rem;
    border-radius: var(--radius-pill);
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.01em;
    transition:
      width 620ms cubic-bezier(0.34, 1.35, 0.64, 1),
      min-height 620ms cubic-bezier(0.34, 1.35, 0.64, 1),
      padding 620ms cubic-bezier(0.34, 1.35, 0.64, 1),
      color var(--duration-default) var(--ease),
      background-color var(--duration-default) var(--ease);
  }

  .wordmark {
    width: var(--space-8);
    color: var(--heading);
  }

  .nav-pill[data-scrolling] .wordmark,
  .nav-pill[data-scrolling] .nav-links a {
    width: 1.75rem;
    min-height: 1.75rem;
    padding: 0;
    transition-duration: 160ms;
    transition-timing-function: var(--ease);
  }

  .mark-stack {
    --mark-wind: 0deg;
    position: relative;
    display: block;
    width: 1.55rem;
    aspect-ratio: 1;
    transform: rotate(var(--mark-wind));
    transform-origin: center;
    will-change: transform;
  }

  .nav-pill[data-scrolling] .mark-stack {
    width: 1.35rem;
  }

  .mark-stack :global(img) {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity var(--duration-default) var(--ease), transform var(--duration-default) var(--ease);
  }

  .mark-stack :global(.mark-blue) {
    opacity: 0;
  }

  :global(html.pointer-moved) .wordmark:hover .mark-stack :global(.mark-red),
  .wordmark:focus-visible .mark-stack :global(.mark-red) {
    opacity: 0;
  }

  :global(html.pointer-moved) .wordmark:hover .mark-stack :global(.mark-blue),
  .wordmark:focus-visible .mark-stack :global(.mark-blue) {
    opacity: 1;
    transform: rotate(4deg);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .nav-links a {
    position: relative;
    width: 3.7rem;
    overflow: hidden;
    padding-inline: var(--space-2);
    color: var(--ink-muted);
  }

  .nav-label,
  .nav-icon {
    transition:
      opacity var(--duration-default) var(--ease),
      transform 620ms cubic-bezier(0.34, 1.35, 0.64, 1);
  }

  .nav-icon {
    position: absolute;
    display: grid;
    width: 1rem;
    aspect-ratio: 1;
    place-items: center;
    opacity: 0;
    transform: scale(0.72);
  }

  .nav-icon svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .nav-pill[data-scrolling] .nav-label {
    opacity: 0;
    transform: scale(0.72);
  }

  .nav-pill[data-scrolling] .nav-icon {
    opacity: 1;
    transform: scale(1);
  }

  .nav-links a[aria-current='page'] {
    color: var(--heading);
    background: var(--hover-fill);
  }

  :global(html.pointer-moved) .wordmark:hover,
  :global(html.pointer-moved) .nav-links a:hover {
    color: var(--heading);
    background: var(--hover-fill);
  }

  @media (max-width: 45rem) {
    .nav-pill {
      width: min(100%, 20.5rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-pill,
    .nav-pill[data-scrolling],
    .wordmark,
    .nav-links a,
    .nav-label,
    .nav-icon {
      transform: none;
      transition: none;
    }

    .mark-stack {
      transform: none;
    }

    .mark-stack :global(img) {
      transition: none;
    }
  }
</style>
