---
import type { ProjectItem } from '../data/site';
import ProjectArtifact from './ProjectArtifact.astro';

interface Props {
  projects: ProjectItem[];
}

const { projects } = Astro.props;
---

<ol class="project-index">
  {projects.map((project, index) => (
    <li class="project-entry">
      <a class="project-row" href={project.href}>
        <div class="project-copy">
          <div class="project-heading">
            <span class="project-number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
            <h3>{project.title}</h3>
            <span class="project-date">{project.date}</span>
          </div>
          <p>{project.blurb}</p>
          <div class="project-foot">
            <span>{project.meta}</span>
            <span class="visit" aria-hidden="true">visit <i>↗</i></span>
          </div>
        </div>

        <div class="artifact-slot">
          <ProjectArtifact variant={project.artifact} />
        </div>
      </a>
    </li>
  ))}
</ol>

<style>
  .project-index {
    width: min(860px, calc(100% - 48px));
    margin-inline: auto;
    padding: 0;
    border-top: 1px solid var(--hairline);
    list-style: none;
  }

  .project-entry {
    margin: 0;
  }

  .project-row {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 11.5rem;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
    min-height: 10.5rem;
    padding: 2rem .75rem 2.15rem;
    color: inherit;
    text-decoration: none;
    isolation: isolate;
  }

  .project-row::before,
  .project-row::after {
    position: absolute;
    content: '';
    pointer-events: none;
  }

  .project-row::before {
    inset: .35rem 0;
    z-index: -1;
    border-radius: var(--radius-md);
    background: var(--accent-soft);
    opacity: 0;
    transform: scale(.985);
    transition:
      opacity var(--duration-fast) var(--ease),
      transform var(--duration-default) var(--ease);
  }

  .project-row::after {
    right: 0;
    bottom: 0;
    left: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--hairline) 9%, var(--hairline) 91%, transparent);
  }

  .project-entry:nth-child(even) .project-row {
    grid-template-columns: 11.5rem minmax(0, 1fr);
  }

  .project-entry:nth-child(even) .project-copy {
    grid-column: 2;
  }

  .project-entry:nth-child(even) .artifact-slot {
    grid-row: 1;
    grid-column: 1;
  }

  .project-copy {
    min-width: 0;
  }

  .project-heading {
    display: grid;
    grid-template-columns: 1.5rem minmax(0, 1fr) auto;
    gap: .75rem;
    align-items: baseline;
  }

  .project-heading h3 {
    margin: 0;
    color: var(--heading);
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -.015em;
  }

  .project-number,
  .project-date,
  .project-foot {
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: .75rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: .02em;
  }

  .project-number {
    color: var(--accent);
  }

  .project-date {
    white-space: nowrap;
  }

  .project-copy > p {
    max-width: 31rem;
    margin: .65rem 0 1rem 2.25rem;
    color: var(--ink-muted);
    font-size: 1rem;
    line-height: 1.65;
  }

  .project-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-left: 2.25rem;
  }

  .visit {
    display: inline-flex;
    gap: .35rem;
    align-items: center;
    color: var(--accent);
    opacity: .72;
  }

  .visit i {
    font-family: var(--font-body);
    font-size: .875rem;
    font-style: normal;
    transition: translate var(--duration-fast) var(--ease);
  }

  .artifact-slot {
    display: grid;
    place-items: center;
    min-width: 0;
  }

  .project-entry:nth-child(3n + 1) .artifact-slot {
    translate: 0 -.3rem;
  }

  .project-entry:nth-child(3n + 2) .artifact-slot {
    translate: .4rem .25rem;
  }

  .project-entry:nth-child(3n) .artifact-slot {
    translate: -.25rem .2rem;
  }

  .project-row:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: var(--radius-md);
  }

  @media (hover: hover) and (pointer: fine) {
    .project-row:hover::before,
    .project-row:focus-visible::before {
      opacity: .36;
      transform: scale(1);
    }

    .project-row:hover .visit i,
    .project-row:focus-visible .visit i {
      translate: .12rem -.12rem;
    }

    .project-row:hover :global(.project-artifact),
    .project-row:focus-visible :global(.project-artifact) {
      translate: 0 -.25rem;
      rotate: 1deg;
    }

    .project-entry:nth-child(even) .project-row:hover :global(.project-artifact),
    .project-entry:nth-child(even) .project-row:focus-visible :global(.project-artifact) {
      rotate: -1deg;
    }
  }

  @media (max-width: 680px) {
    .project-index {
      width: min(100% - 32px, 42rem);
    }

    .project-row,
    .project-entry:nth-child(even) .project-row {
      grid-template-columns: minmax(0, 1fr) clamp(7.25rem, 29vw, 9rem);
      gap: 1.25rem;
      min-height: 9rem;
      padding: 1.5rem .25rem 1.65rem;
    }

    .project-entry:nth-child(even) .project-copy {
      grid-column: 1;
    }

    .project-entry:nth-child(even) .artifact-slot {
      grid-row: 1;
      grid-column: 2;
    }

    .project-heading {
      grid-template-columns: 1.25rem minmax(0, 1fr);
      gap: .55rem;
    }

    .project-date {
      grid-column: 2;
      margin-top: .15rem;
    }

    .project-copy > p,
    .project-foot {
      margin-left: 1.8rem;
    }

    .project-copy > p {
      margin-top: .5rem;
      margin-bottom: .7rem;
      font-size: .875rem;
      line-height: 1.45;
    }

    .visit {
      display: none;
    }

    .project-entry:nth-child(n) .artifact-slot {
      translate: none;
    }
  }

  @media (max-width: 430px) {
    .project-row,
    .project-entry:nth-child(even) .project-row {
      grid-template-columns: minmax(0, 1fr) 6.75rem;
      gap: .7rem;
    }

    .project-foot {
      display: block;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-row::before,
    .visit i,
    .project-row :global(.project-artifact) {
      transition: opacity var(--duration-fast) linear;
    }
  }
</style>
