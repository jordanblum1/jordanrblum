---
import { Image } from 'astro:assets';
import type { WorkVisual as WorkVisualName } from '../data/site';
import aliveActivity from '../assets/projects/alive-activity.png';
import aliveHome from '../assets/projects/alive-home.png';
import aliveTrip from '../assets/projects/alive-trip.png';
import chicksLogo from '../assets/projects/chicks-logo.png';
import citibikeWrapped from '../assets/projects/citibike-wrapped.webp';

interface Props {
  visual: WorkVisualName;
  size?: 'feature' | 'compact';
}

const { visual, size = 'feature' } = Astro.props;

---

<div class:list={['work-visual', `visual-${visual}`, `visual-${size}`]} aria-hidden="true">
  {visual === 'roam' && (
    <div class="study study-roam">
      <div class="roam-window">
        <div class="window-bar">
          <span class="window-mark" aria-hidden="true"></span>
          <span>Reed / home research</span>
          <span class="window-status">3 sources</span>
        </div>
        <div class="roam-content">
          <div class="roam-prompt">
            <span class="prompt-kicker">Question</span>
            <strong>What should I know about this home?</strong>
          </div>
          <div class="roam-answer">
            <div class="answer-heading">
              <span class="answer-spark" aria-hidden="true">✦</span>
              <span>Here’s the short version</span>
            </div>
            <span class="answer-line answer-line-long"></span>
            <span class="answer-line"></span>
            <span class="answer-line answer-line-short"></span>
          </div>
          <div class="source-row">
            <span>Listing details</span>
            <span>Neighborhood</span>
            <span>Pricing</span>
          </div>
        </div>
      </div>
    </div>
  )}

  {visual === 'alive' && (
    <div class="alive-stage">
      <div class="alive-phones">
        <div class="alive-phone alive-phone-left">
          <span class="alive-side-button" aria-hidden="true"></span>
          <div class="alive-screen">
            <Image
              src={aliveTrip}
              alt=""
              widths={[240, 360, 480]}
              sizes="(max-width: 44rem) 28vw, 14vw"
              loading="lazy"
              class="alive-screen-image alive-device-image"
            />
          </div>
        </div>

        <div class="alive-phone alive-phone-center">
          <span class="alive-side-button" aria-hidden="true"></span>
          <div class="alive-screen">
            <Image
              src={aliveHome}
              alt=""
              widths={[280, 420, 560]}
              sizes="(max-width: 44rem) 34vw, 17vw"
              loading="lazy"
              class="alive-screen-image"
            />
          </div>
        </div>

        <div class="alive-phone alive-phone-right">
          <span class="alive-side-button" aria-hidden="true"></span>
          <div class="alive-screen">
            <Image
              src={aliveActivity}
              alt=""
              widths={[240, 360, 480]}
              sizes="(max-width: 44rem) 28vw, 14vw"
              loading="lazy"
              class="alive-screen-image"
            />
          </div>
        </div>
      </div>
    </div>
  )}

  {visual === 'procore' && (
    <div class="study study-procore">
      <div class="deploy-panel">
        <div class="deploy-head">
          <div>
            <span class="panel-kicker">Deployment</span>
            <strong>payments-api</strong>
          </div>
          <span class="ready-pill"><i aria-hidden="true"></i> Ready</span>
        </div>
        <dl class="deploy-details">
          <div><dt>Environment</dt><dd>Production</dd></div>
          <div><dt>Version</dt><dd>v2.18.4</dd></div>
          <div><dt>Checks</dt><dd>12 / 12</dd></div>
        </dl>
        <div class="deploy-track" aria-hidden="true">
          <span class="track-fill"></span>
          <i></i><i></i><i></i><i></i>
        </div>
        <div class="deploy-steps">
          <span>Build</span><span>Test</span><span>Review</span><span>Release</span>
        </div>
      </div>
    </div>
  )}

  {visual === 'chicks' && (
    <div class="chicks-stage">
      <span class="chicks-ring" aria-hidden="true"></span>
      <Image
        src={chicksLogo}
        alt=""
        widths={[280, 420, 560]}
        sizes="(max-width: 44rem) 55vw, 22vw"
        loading="lazy"
        class="chicks-image"
      />
    </div>
  )}

  {visual === 'citibike' && (
    <div class="citibike-stage">
      <div class="citibike-scene">
        <Image
          src={citibikeWrapped}
          alt=""
          widths={[400, 640, 800]}
          sizes="(max-width: 44rem) 100vw, 33vw"
          loading="lazy"
          class="citibike-image"
        />
        <svg
          class="citibike-fountain"
          viewBox="0 0 2400 1792"
          preserveAspectRatio="xMidYMid slice"
          fill="none"
          aria-hidden="true"
        >
          <g class="fountain-jet fountain-jet-left">
            <path
              class="fountain-stream fountain-stream-left"
              pathLength="1"
              d="M1538 555C1400 505 1160 530 930 645"
            />
          </g>
          <g class="fountain-jet fountain-jet-center">
            <path
              class="fountain-stream fountain-stream-center fountain-stream-near"
              pathLength="1"
              d="M1538 555C1538 530 1538 505 1538 482"
            />
            <path
              class="fountain-stream fountain-stream-center fountain-stream-emerge"
              pathLength="1"
              d="M1538 348C1538 235 1540 40 1540-120"
            />
          </g>
          <g class="fountain-jet fountain-jet-right">
            <path
              class="fountain-stream fountain-stream-right fountain-stream-near"
              pathLength="1"
              d="M1538 555C1562 520 1584 500 1608 482"
            />
            <path
              class="fountain-stream fountain-stream-right fountain-stream-emerge"
              pathLength="1"
              d="M1748 292C1960 184 2230 190 2480 350"
            />
          </g>
          <ellipse class="fountain-ripple" cx="930" cy="645" rx="60" ry="14" pathLength="1" />
          <circle class="fountain-drop fountain-drop-1" cx="908" cy="625" r="8" />
          <circle class="fountain-drop fountain-drop-2" cx="937" cy="614" r="6" />
          <circle class="fountain-drop fountain-drop-3" cx="956" cy="630" r="7" />
        </svg>
      </div>
    </div>
  )}

  {visual === 'workday' && (
    <div class="study study-workday">
      <div class="release-board">
        <div class="release-sidebar">
          <span class="release-logo" aria-hidden="true">JB</span>
          <span class="sidebar-line sidebar-line-active"></span>
          <span class="sidebar-line"></span>
          <span class="sidebar-line"></span>
          <span class="sidebar-line sidebar-line-short"></span>
        </div>
        <div class="release-main">
          <div class="release-topline">
            <div>
              <span class="panel-kicker">Release train</span>
              <strong>April candidate</strong>
            </div>
            <span class="ready-pill"><i aria-hidden="true"></i> On track</span>
          </div>
          <div class="release-columns">
            <div class="test-card">
              <span class="panel-kicker">Tests found</span>
              <strong>148</strong>
              <span class="test-note">across 12 suites</span>
            </div>
            <div class="release-timeline">
              <div><i aria-hidden="true"></i><span><b>Candidate built</b><small>09:42</small></span></div>
              <div><i aria-hidden="true"></i><span><b>Checks complete</b><small>10:16</small></span></div>
              <div><i aria-hidden="true"></i><span><b>Ready to release</b><small>Now</small></span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  )}
</div>

<style>
  .work-visual {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 0;
    overflow: hidden;
    color: var(--ink);
    background: var(--paper-raised);
  }

  .study,
  .alive-stage,
  .chicks-stage,
  .citibike-stage {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .panel-kicker,
  .prompt-kicker {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    line-height: 1.45;
    letter-spacing: 0.01em;
  }

  .study-roam {
    display: grid;
    place-items: center;
    padding: clamp(var(--space-12), 7vw, var(--space-24)) clamp(var(--space-6), 5vw, var(--space-16)) var(--space-8);
    background:
      radial-gradient(circle at 86% 14%, var(--accent-soft), transparent 30%),
      linear-gradient(145deg, var(--paper-raised), color-mix(in oklab, var(--paper) 82%, var(--accent-soft)));
  }

  .roam-window {
    width: min(100%, 39rem);
    overflow: hidden;
    background: var(--paper-raised);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-lifted);
    transform: rotate(-1.2deg);
  }

  .window-bar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-2);
    align-items: center;
    min-height: var(--space-12);
    padding-inline: var(--space-4);
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    border-bottom: 1px solid var(--hairline);
  }

  .window-mark {
    width: var(--space-2);
    aspect-ratio: 1;
    background: var(--accent);
    border-radius: 50%;
  }

  .window-status {
    color: var(--success);
  }

  .roam-content {
    display: grid;
    gap: var(--space-4);
    padding: clamp(var(--space-4), 3.5vw, var(--space-8));
  }

  .roam-prompt,
  .roam-answer {
    display: grid;
    gap: var(--space-2);
  }

  .roam-prompt {
    width: 78%;
    justify-self: end;
    padding: var(--space-3) var(--space-4);
    background: var(--accent-soft);
    border-radius: var(--radius-sm) var(--radius-sm) var(--radius-xs) var(--radius-sm);
  }

  .prompt-kicker,
  .panel-kicker {
    color: var(--ink-muted);
  }

  .roam-prompt strong,
  .answer-heading {
    font-size: clamp(0.76rem, 1.4vw, 0.9rem);
    font-weight: 500;
    line-height: 1.3;
  }

  .roam-answer {
    max-width: 82%;
    padding: var(--space-3) 0;
  }

  .answer-heading {
    display: flex;
    gap: var(--space-2);
    align-items: center;
    margin-bottom: var(--space-1);
  }

  .answer-spark {
    color: var(--accent);
  }

  .answer-line {
    display: block;
    width: 78%;
    height: 0.38rem;
    background: color-mix(in oklab, var(--ink-muted) 22%, transparent);
    border-radius: var(--radius-xs);
  }

  .answer-line-long { width: 100%; }
  .answer-line-short { width: 56%; }

  .source-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .source-row span {
    padding: var(--space-1) var(--space-2);
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-xs);
  }

  .alive-stage {
    isolation: isolate;
    background:
      radial-gradient(circle at 50% 46%, color-mix(in oklab, var(--success) 18%, transparent), transparent 42%),
      linear-gradient(145deg, color-mix(in oklab, var(--paper-raised) 90%, var(--success)), var(--paper-raised));
  }

  .alive-stage::before {
    position: absolute;
    inset: 12% 8% -36%;
    background: color-mix(in oklab, var(--success) 8%, transparent);
    border-radius: var(--radius-pill) var(--radius-pill) 0 0;
    content: '';
  }

  .alive-phones {
    position: absolute;
    inset: 0;
  }

  .alive-phone {
    position: absolute;
    bottom: -8%;
    aspect-ratio: 1206 / 2622;
    padding: clamp(0.16rem, 0.42vw, 0.3rem);
    background: linear-gradient(
      145deg,
      color-mix(in oklab, var(--ink) 62%, var(--paper-raised)),
      var(--ink) 42%,
      color-mix(in oklab, var(--ink) 76%, var(--paper-raised))
    );
    border: 1px solid color-mix(in oklab, var(--paper-raised) 30%, var(--ink));
    border-radius: var(--radius-lg);
    box-shadow:
      0 var(--space-5) var(--space-10) color-mix(in oklab, var(--ink) 22%, transparent),
      inset 0 0 0 1px color-mix(in oklab, var(--paper-raised) 16%, transparent);
    transform-origin: 50% 100%;
  }

  .alive-phone-left {
    left: 27%;
    z-index: 1;
    height: 90%;
    transform: translateX(-50%) rotate(-5deg);
  }

  .alive-phone-center {
    left: 50%;
    z-index: 3;
    height: 104%;
    transform: translateX(-50%);
  }

  .alive-phone-right {
    right: 27%;
    z-index: 2;
    height: 90%;
    transform: translateX(50%) rotate(5deg);
  }

  .alive-screen {
    position: absolute;
    inset: clamp(0.16rem, 0.42vw, 0.3rem);
    overflow: hidden;
    background: var(--paper-raised);
    border-radius: calc(var(--radius-lg) - var(--space-1));
  }

  .alive-side-button {
    position: absolute;
    top: 24%;
    left: -0.22rem;
    width: 0.18rem;
    height: 16%;
    background: color-mix(in oklab, var(--ink) 72%, var(--paper-raised));
    border-radius: var(--radius-pill);
  }

  :global(.alive-screen-image) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .study-procore {
    display: grid;
    place-items: center;
    padding: var(--space-12) clamp(var(--space-4), 3vw, var(--space-8)) var(--space-6);
    background:
      linear-gradient(color-mix(in oklab, var(--hairline) 38%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in oklab, var(--hairline) 38%, transparent) 1px, transparent 1px),
      color-mix(in oklab, var(--paper) 88%, var(--success));
    background-size: var(--space-6) var(--space-6);
  }

  .deploy-panel {
    width: min(100%, 23rem);
    padding: clamp(var(--space-4), 3vw, var(--space-6));
    background: var(--paper-raised);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-lifted);
    transform: rotate(1deg);
  }

  .deploy-head,
  .release-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .deploy-head > div,
  .release-topline > div {
    display: grid;
    gap: var(--space-1);
  }

  .deploy-head strong,
  .release-topline strong {
    font-size: clamp(0.82rem, 1.5vw, 1rem);
    font-weight: 500;
  }

  .ready-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-2);
    color: var(--success);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    white-space: nowrap;
    background: color-mix(in oklab, var(--success) 11%, var(--paper-raised));
    border-radius: var(--radius-sm);
  }

  .ready-pill i {
    width: var(--space-1);
    aspect-ratio: 1;
    background: currentColor;
    border-radius: 50%;
  }

  .deploy-details {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2);
    margin: var(--space-6) 0;
  }

  .deploy-details > div {
    display: grid;
    gap: var(--space-1);
  }

  .deploy-details dt,
  .deploy-details dd,
  .deploy-steps {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.58rem;
  }

  .deploy-details dt { color: var(--ink-muted); }
  .deploy-details dd { font-weight: 500; }

  .deploy-track {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: var(--space-3);
  }

  .deploy-track::before,
  .track-fill {
    position: absolute;
    right: 0;
    left: 0;
    height: 1px;
    background: var(--hairline);
    content: '';
  }

  .track-fill {
    right: 5%;
    z-index: 1;
    background: var(--success);
  }

  .deploy-track i {
    z-index: 2;
    width: var(--space-2);
    aspect-ratio: 1;
    background: var(--success);
    border: 2px solid var(--paper-raised);
    border-radius: 50%;
    box-shadow: 0 0 0 1px var(--success);
  }

  .deploy-steps {
    display: flex;
    justify-content: space-between;
    margin-top: var(--space-1);
    color: var(--ink-muted);
  }

  .chicks-stage {
    display: grid;
    place-items: center;
    padding: var(--space-8);
    background: color-mix(in oklab, var(--warning) 12%, var(--paper-raised));
  }

  .chicks-stage::before,
  .chicks-stage::after,
  .chicks-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    aspect-ratio: 1;
    border: 1px solid color-mix(in oklab, var(--warning) 28%, transparent);
    border-radius: 50%;
    content: '';
    opacity: 0.72;
    transform: translate(-50%, -50%) scale(0.98);
    transition:
      transform 560ms cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 360ms var(--ease),
      border-color 360ms var(--ease);
  }

  .chicks-stage::before { width: 76%; }
  .chicks-stage::after { width: 58%; }
  .chicks-ring {
    width: 92%;
    transition-delay: 45ms;
  }

  :global(.chicks-image) {
    z-index: 1;
    width: min(72%, 17rem);
    height: auto;
    filter: drop-shadow(var(--shadow-small));
    transform-origin: 50% 62%;
  }

  @keyframes chicks-hop {
    0% { transform: translateY(0) rotate(0) scale(1); }
    38% { transform: translateY(calc(var(--space-5) * -1)) rotate(-5deg) scale(1.04); }
    66% { transform: translateY(var(--space-1)) rotate(2deg) scale(0.985); }
    100% { transform: translateY(calc(var(--space-1) * -1)) rotate(-1deg) scale(1.01); }
  }

  @keyframes alive-phone-left {
    0%,
    100% { transform: translateX(-50%) rotate(-5deg); }
    42% { transform: translate(-56%, -6px) rotate(-8deg); }
    72% { transform: translate(-48%, 2px) rotate(-4deg); }
  }

  @keyframes alive-phone-center {
    0%,
    100% { transform: translateX(-50%); }
    42% { transform: translate(-50%, -12px) scale(1.015); }
    72% { transform: translate(-50%, 2px) scale(0.997); }
  }

  @keyframes alive-phone-right {
    0%,
    100% { transform: translateX(50%) rotate(5deg); }
    42% { transform: translate(56%, -6px) rotate(8deg); }
    72% { transform: translate(48%, 2px) rotate(4deg); }
  }

  @keyframes citibike-coast {
    0%,
    100% { transform: translate3d(0, 0, 0) scale(1); }
    38% { transform: translate3d(-4px, -3px, 0) scale(1.012); }
    68% { transform: translate3d(2px, 2px, 0) scale(1.006); }
  }

  @keyframes citibike-glint {
    0% {
      opacity: 0;
      transform: translateX(-280%) skewX(-12deg);
    }
    28% { opacity: 0.34; }
    100% {
      opacity: 0;
      transform: translateX(780%) skewX(-12deg);
    }
  }

  @keyframes fountain-spout {
    0% {
      opacity: 0.72;
      stroke-dashoffset: 154px;
    }
    46% { opacity: 0.82; }
    100% {
      opacity: 0.72;
      stroke-dashoffset: 0;
    }
  }

  @keyframes fountain-ripple {
    0% {
      opacity: 0;
      transform: scaleX(0.35);
    }
    58% { opacity: 0.58; }
    100% {
      opacity: 0;
      transform: scaleX(1.15);
    }
  }

  @keyframes fountain-drop {
    0% {
      opacity: 0;
      transform: translateY(var(--space-2));
    }
    42% { opacity: 0.74; }
    100% {
      opacity: 0;
      transform: translateY(calc(var(--space-3) * -1));
    }
  }

  @media (hover: hover) and (pointer: fine) {
    :global(.project-link:hover) .alive-phone-left,
    :global(.project-link:focus-visible) .alive-phone-left {
      animation: alive-phone-left 640ms cubic-bezier(0.34, 1.56, 0.64, 1) 1 both;
    }

    :global(.project-link:hover) .alive-phone-center,
    :global(.project-link:focus-visible) .alive-phone-center {
      animation: alive-phone-center 640ms 35ms cubic-bezier(0.34, 1.56, 0.64, 1) 1 both;
    }

    :global(.project-link:hover) .alive-phone-right,
    :global(.project-link:focus-visible) .alive-phone-right {
      animation: alive-phone-right 640ms 70ms cubic-bezier(0.34, 1.56, 0.64, 1) 1 both;
    }

    :global(.project-link:hover) .chicks-stage::before,
    :global(.project-link:focus-visible) .chicks-stage::before {
      opacity: 0.92;
      transform: translate(-50%, -50%) scale(1.16);
    }

    :global(.project-link:hover) .chicks-stage::after,
    :global(.project-link:focus-visible) .chicks-stage::after {
      opacity: 0.28;
      transform: translate(-50%, -50%) scale(0.83);
    }

    :global(.project-link:hover) .chicks-ring,
    :global(.project-link:focus-visible) .chicks-ring {
      opacity: 0.22;
      transform: translate(-50%, -50%) scale(1.13);
    }

    :global(.project-link:hover) :global(.chicks-image),
    :global(.project-link:focus-visible) :global(.chicks-image) {
      animation: chicks-hop 620ms cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    :global(.project-link:hover) .citibike-scene,
    :global(.project-link:focus-visible) .citibike-scene {
      animation: citibike-coast 620ms cubic-bezier(0.34, 1.56, 0.64, 1) 1 both;
    }

    :global(.project-link:hover) .citibike-stage::after,
    :global(.project-link:focus-visible) .citibike-stage::after {
      animation: citibike-glint 760ms var(--ease) 1 both;
    }

    :global(.project-link:hover) .fountain-stream,
    :global(.project-link:focus-visible) .fountain-stream {
      animation: fountain-spout 5600ms var(--fountain-delay, 0ms) linear infinite;
    }

    :global(.project-link:hover) .fountain-stream-left,
    :global(.project-link:focus-visible) .fountain-stream-left {
      --fountain-delay: 180ms;
    }

    :global(.project-link:hover) .fountain-jet-center .fountain-stream-near,
    :global(.project-link:focus-visible) .fountain-jet-center .fountain-stream-near {
