---
// Chat chrome uses Baloo 2 Regular for chip/label legibility. The header uses
// the site's existing BLUM mark instead of loading a second display face.
import '@fontsource/baloo-2/latin-400.css';
import blumMarkSource from '../assets/identity/blum-mark.svg?raw';

const blumMark = blumMarkSource
  .replace(/<\?xml[^>]*>\s*/, '')
  .replace(/<defs>[\s\S]*?<\/defs>/, '');

// Starter questions wear a recruiter's hat: what someone reaching out cold
// would actually ask, with no insider knowledge assumed (no company names).
const starters = [
  "What's his recent work experience?",
  'What has he built?',
  "What's his tech stack?",
  'Can I download his resume?',
  'How can I get in touch?',
];
---

<div class="chat-widget" data-chat-widget>
  <section
    id="chat-panel"
    class="chat-panel"
    role="dialog"
    aria-modal="true"
    aria-label="Chat with Jordy, Jordan’s assistant"
    data-chat-panel
    hidden
  >
    <header class="chat-header">
      <!-- The BLUM mark is the only visible header identity. The hidden text
           keeps the dialog heading useful without repeating visible copy. -->
      <h2 id="chat-panel-title" class="chat-name">
        <span class="chat-logo" data-chat-logo aria-hidden="true" set:html={blumMark}></span>
        <span class="visually-hidden">Jordy</span>
      </h2>
      <button type="button" class="chat-close" data-chat-close aria-label="Close chat">
        <svg aria-hidden="true" viewBox="0 0 20 20" fill="none">
          <path d="m5 5 10 10M15 5 5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </button>
    </header>

    <div class="chat-body" data-chat-scroll>
      <div class="chat-intro" data-chat-intro>
        <p class="chat-intro-copy">
          Hey — I’m Jordy, Jordan’s assistant. I can give you the quick version of his work, side projects, and
          background. Pick a question below, or ask your own.
        </p>
        <div class="chat-starters" role="group" aria-label="Suggested questions">
          {starters.map((starter) => <button type="button" class="chat-chip" data-chat-chip>{starter}</button>)}
        </div>
      </div>
      <div class="chat-log" data-chat-log></div>
    </div>

    <!-- The transcript above is deliberately not a live region (replies buffer
         behind the typing indicator and reveal whole, and reopening re-renders
         history — both would spam screen readers if live). This hidden region
         announces only completed replies and error/limit notices. -->
    <div class="visually-hidden" aria-live="polite" data-chat-announce></div>

    <div class="chat-float">
      <button type="button" class="chat-pill chat-jump" data-chat-jump hidden>
        Jump to latest <span aria-hidden="true">↓</span>
      </button>
    </div>

    <p class="chat-notice" data-chat-notice hidden></p>

    <p class="chat-count" data-chat-count hidden aria-hidden="true"></p>

    <form class="chat-form" data-chat-form>
      <label class="visually-hidden" for="chat-input">Message Jordy, Jordan’s assistant</label>
      <div class="chat-composer" data-chat-composer>
        <textarea
          id="chat-input"
          class="chat-input"
          data-chat-input
          rows="1"
          maxlength="2000"
          placeholder="Ask Jordy about Jordan…"
          autocomplete="off"
          aria-describedby="chat-input-hint"
        ></textarea>
        <button type="submit" class="chat-send" data-chat-send aria-label="Send message" disabled>
          <span class="chat-send-arrow" aria-hidden="true">↑</span>
        </button>
      </div>
      <span id="chat-input-hint" class="visually-hidden">
        Press Enter to send, Shift and Enter for a new line. Messages can be up to 2000 characters.
      </span>
    </form>

  </section>
</div>

<script src="../scripts/chat.ts"></script>

<style>
  .chat-widget {
    position: fixed;
    right: var(--space-6);
    bottom: var(--space-6);
    z-index: 60;
  }

  /* There is no floating launcher: the panel opens only from the nav "Chat"
     button and the footer CTA (both `data-chat-trigger`, via chat.ts's
     openChat/toggleChat API). No-JS visitors never see any of it — `html.js`
     is added synchronously in <head> before the body is parsed, and the
     triggers hide themselves the same way. */
  :global(html:not(.js)) .chat-widget {
    display: none;
  }

  .chat-panel[hidden] {
    display: none;
  }

  .chat-panel {
    /* Warning text on the 12%-warning-mix surface: raw --warning lands at
       3.54:1, below WCAG AA. Mixing 70% warning into ink yields ~#80572f,
       5.3:1 on that surface, while staying inside the token system. */
    --warning-ink: color-mix(in oklab, var(--warning) 70%, var(--ink));
    /* Baloo 2 Regular gives chips a warmer personality while its conventional
         skeletons keep every word instantly legible at 13-14px
         (Sedgwick Ave's lowercase 'k' read as 'h' at chip size; Shantell
         Sans was legible but read plain). Regular, not SemiBold — owner
         wanted the chips lighter/cleaner, and the skeletons carry legibility
         without the extra weight.
       Message text stays in the readable site stack. */
    position: fixed;
    right: var(--space-6);
    bottom: var(--space-6);
    display: flex;
    width: min(25.5rem, calc(100vw - var(--space-8)));
    max-height: min(37rem, calc(100vh - 6.5rem));
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-xl);
    background: var(--paper-raised);
    box-shadow: var(--shadow-lifted);
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    transform-origin: calc(100% - var(--space-6)) calc(100% - var(--space-6));
    transition:
      opacity var(--duration-default) var(--ease),
      transform var(--duration-slow) var(--spring),
      box-shadow var(--duration-slow) var(--ease);
  }

  /* The shell unfolds from the composer corner while its shadow lifts. The
     child planes settle in behind it with a short tokenized stagger below. */
  .chat-panel:not(.is-open) {
    opacity: 0;
    transform: translate3d(var(--space-2), var(--space-4), 0) scale(0.98);
    box-shadow: var(--shadow-small);
    transition-duration: var(--duration-slow), var(--duration-slow), var(--duration-slow);
    pointer-events: none;
  }

  .chat-header,
  .chat-body,
  .chat-form {
    opacity: 1;
    transform: translate3d(0, 0, 0);
    transition:
      opacity var(--duration-fast) var(--ease),
      transform var(--duration-default) var(--spring);
  }

  .chat-panel.is-open .chat-header {
    transition-delay: var(--duration-stagger);
  }

  .chat-panel.is-open .chat-body {
    transition-delay: calc(var(--duration-stagger) + var(--duration-stagger));
  }

  .chat-panel.is-open .chat-form {
    transition-delay: calc(var(--duration-stagger) + var(--duration-stagger) + var(--duration-stagger));
  }

  .chat-panel:not(.is-open) .chat-header,
  .chat-panel:not(.is-open) .chat-body,
  .chat-panel:not(.is-open) .chat-form {
    opacity: 0;
    transition-delay: 0ms;
  }

  .chat-panel:not(.is-open) .chat-header {
    transform: translate3d(0, var(--space-2), 0);
  }

  .chat-panel:not(.is-open) .chat-body {
    transform: translate3d(0, var(--space-3), 0);
  }

  .chat-panel:not(.is-open) .chat-form {
    transform: translate3d(0, var(--space-2), 0);
  }

  /* The header floats over the shared panel surface — no divider. A soft
     paper→transparent fade hangs below it so scrolled messages sink under the
     title instead of butting into it (a gradient, deliberately not a line). */
  .chat-header {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5) var(--space-2);
  }

  .chat-header::after {
    content: '';
    position: absolute;
    top: 100%;
    right: 0;
    left: 0;
    height: 1.5rem;
    background: linear-gradient(to bottom, var(--paper-raised), transparent);
    pointer-events: none;
  }

  .chat-name {
    width: 5rem;
    margin: 0;
    color: var(--accent);
    line-height: 0;
  }

  .chat-logo,
  .chat-logo :global(svg) {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .chat-logo :global(.logo-piece) {
    --piece-x: 0;
    --piece-y: var(--space-1);
    --piece-rotate: 0deg;
    transform-box: fill-box;
    transform-origin: center;
  }

  .chat-logo :global(path) {
    fill: var(--accent);
    fill-opacity: 1;
    stroke: var(--accent);
    stroke-dasharray: 1;
    stroke-dashoffset: 0;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-opacity: 0;
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }

  .chat-logo :global(.logo-piece-1) {
    --piece-x: calc(-1 * var(--space-2));
    --piece-rotate: -4deg;
  }

  .chat-logo :global(.logo-piece-2) {
    --piece-x: calc(-1 * var(--space-1));
    --piece-y: var(--space-2);
    --piece-rotate: 3deg;
  }

  .chat-logo :global(.logo-piece-3) {
    --piece-x: var(--space-1);
    --piece-y: calc(-1 * var(--space-1));
    --piece-rotate: -3deg;
  }

  .chat-logo :global(.logo-piece-4) {
    --piece-x: var(--space-2);
    --piece-rotate: 4deg;
  }

  .chat-panel.is-open .chat-logo :global(.logo-piece) {
    animation: chat-blum-assemble var(--duration-slow) var(--ease) backwards;
  }

  .chat-panel.is-open .chat-logo :global(.logo-piece path) {
    animation: chat-blum-ink var(--duration-slow) var(--ease) backwards;
  }

  .chat-panel.is-open .chat-logo :global(.logo-piece-2),
  .chat-panel.is-open .chat-logo :global(.logo-piece-2 path) {
    animation-delay: 40ms;
  }

  .chat-panel.is-open .chat-logo :global(.logo-piece-3),
  .chat-panel.is-open .chat-logo :global(.logo-piece-3 path) {
    animation-delay: 80ms;
  }

  .chat-panel.is-open .chat-logo :global(.logo-piece-4),
  .chat-panel.is-open .chat-logo :global(.logo-piece-4 path) {
    animation-delay: 120ms;
  }

  @keyframes chat-blum-assemble {
    0% {
      transform: translate3d(var(--piece-x), var(--piece-y), 0) rotate(var(--piece-rotate)) scale(0.94);
    }

    72% {
      transform: translate3d(0, -0.08rem, 0) rotate(0deg) scale(1.01);
    }

    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  @keyframes chat-blum-ink {
    0% {
      fill-opacity: 0;
      stroke-dashoffset: 1;
      stroke-opacity: 0;
    }

    12%,
    68% {
      fill-opacity: 0;
      stroke-opacity: 1;
    }

    100% {
      fill-opacity: 1;
      stroke-dashoffset: 0;
      stroke-opacity: 0;
    }
  }

  .chat-close {
    display: grid;
    width: 1.9rem;
    aspect-ratio: 1;
    flex: 0 0 auto;
    place-items: center;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: none;
    color: var(--ink-muted);
    cursor: pointer;
    transition: color var(--duration-default) var(--ease), background-color var(--duration-default) var(--ease);
  }

  .chat-close svg {
    width: 1rem;
    height: 1rem;
  }

  :global(html.pointer-moved) .chat-close:hover {
    color: var(--heading);
    background: var(--hover-fill);
  }

  .chat-body {
    position: relative;
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: var(--space-4);
    overflow-y: auto;
    overscroll-behavior: contain;
    /* Extra bottom padding keeps the floating jump pill clear of the
       last line of a revealed reply. */
    padding: var(--space-3) var(--space-5) var(--space-8);
    min-height: 16rem;
  }

  /* --- Empty state ---------------------------------------------------------- */

  .chat-intro[hidden] {
    display: none;
  }

  /* No heading here — the "ask Jordy" header right above carries the name, so
     the body copy leads the empty state. It steps up slightly in size and
     measure, and the copy→chips gap widens so the state reads settled rather
     than sparse. */
  .chat-intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-block: auto;
    padding-block: var(--space-3);
  }

  .chat-intro-copy {
    color: var(--ink-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    max-width: 32ch;
    text-wrap: pretty;
  }

  .chat-starters {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: flex-start;
  }

  /* Chips are shared between the build-time starters and the runtime follow-ups
     chat.ts creates with document.createElement — the runtime ones never get
     Astro's scoped attribute, so the class must be global. */
  :global(.chat-panel .chat-chip) {
    padding: 0.42rem 0.85rem;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-pill);
    background: var(--paper-raised);
    color: var(--ink);
    font-family: var(--font-ui-accent);
    font-size: 0.85rem;
    font-weight: 400;
    line-height: 1.35;
    text-align: left;
    cursor: pointer;
    transition:
      color var(--duration-default) var(--ease),
      border-color var(--duration-default) var(--ease),
      background-color var(--duration-default) var(--ease);
  }

  :global(html.pointer-moved .chat-panel .chat-chip:hover) {
    color: var(--accent);
    border-color: color-mix(in oklab, var(--accent) 55%, var(--hairline));
    background: var(--accent-soft);
  }

  /* --- Messages ------------------------------------------------------------- */

  .chat-log {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    font-size: 0.86rem;
    line-height: 1.6;
  }

  /* Everything inside the log is created at runtime by chat.ts (bubbles) and
     chat-markdown.ts (p/strong/em/code/pre/ul/ol/a), so none of it carries
     Astro's scoped data attribute — all of these rules must be global. */
  :global(.chat-log .chat-bubble) {
    max-width: 100%;
    text-wrap: pretty;
  }

  :global(.chat-log .chat-bubble.role-user) {
    align-self: flex-end;
    max-width: 85%;
    padding: 0.55rem 0.9rem;
    border-radius: var(--radius-md);
    border-end-end-radius: var(--radius-xs);
    background: var(--accent);
    color: var(--accent-contrast);
    white-space: pre-wrap;
  }

  :global(.chat-log .chat-bubble.role-assistant) {
    align-self: stretch;
    color: var(--ink);
  }

  :global(.chat-log .role-assistant p) {
    margin: 0 0 var(--space-2);
  }

  :global(.chat-log .role-assistant > :last-child) {
    margin-bottom: 0;
  }

  :global(.chat-log .role-assistant strong) {
    font-weight: 600;
    color: var(--heading);
  }

  :global(.chat-log .role-assistant em) {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 450;
  }

  :global(.chat-log .role-assistant code) {
    padding: 0.08em 0.32em;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-xs);
    background: var(--hover-fill);
    font-family: var(--font-mono);
    font-size: 0.82em;
  }

  :global(.chat-log .role-assistant pre) {
    margin: 0 0 var(--space-2);
    padding: var(--space-3);
    overflow-x: auto;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-sm);
    background: color-mix(in oklab, var(--ink) 4%, var(--paper-raised));
  }

  :global(.chat-log .role-assistant pre code) {
    padding: 0;
    border: 0;
    background: none;
    font-size: 0.76rem;
    line-height: 1.55;
  }

  /* Tailwind's preflight strips list styles, so restore real markers. */
  :global(.chat-log .role-assistant ul),
  :global(.chat-log .role-assistant ol) {
    margin: 0 0 var(--space-2);
    padding-left: 1.25rem;
  }

  :global(.chat-log .role-assistant ul) {
    list-style: disc outside;
  }

  :global(.chat-log .role-assistant ol) {
    list-style: decimal outside;
  }

  :global(.chat-log .role-assistant li) {
    margin-block: 0.15em;
  }

  :global(.chat-log .role-assistant li::marker) {
    color: var(--ink-muted);
  }

  :global(.chat-log .role-assistant a) {
    color: var(--heading);
    font-weight: 500;
    text-decoration-line: underline;
    text-decoration-color: color-mix(in oklab, var(--accent) 42%, transparent);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.24em;
    transition: color var(--duration-default) var(--ease), text-decoration-color var(--duration-default) var(--ease);
  }

  :global(html.pointer-moved .chat-log .role-assistant a:hover) {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  :global(.chat-log .chat-bubble.role-system a),
  .chat-notice :global(a) {
    color: inherit;
    font-weight: 500;
    text-decoration-line: underline;
    text-decoration-color: color-mix(in oklab, var(--warning-ink) 55%, transparent);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.22em;
  }

  :global(html.pointer-moved .chat-log .chat-bubble.role-system a:hover),
  :global(html.pointer-moved) .chat-notice :global(a:hover) {
    text-decoration-color: var(--warning-ink);
  }

  :global(.chat-log .chat-bubble.role-system) {
    align-self: center;
    max-width: 100%;
    padding: 0.6rem 0.85rem;
    border: 1px solid color-mix(in oklab, var(--warning) 35%, transparent);
    border-radius: var(--radius-sm);
    background: color-mix(in oklab, var(--warning) 12%, var(--paper-raised));
    color: var(--warning-ink);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-align: center;
  }

  :global(.chat-log .chat-followups) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: calc(-1 * var(--space-2));
  }

  /* --- Resume download ----------------------------------------------------- */

  :global(.chat-log .resume-gate) {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
    border: 1px solid color-mix(in oklab, var(--accent) 24%, var(--hairline));
    border-radius: var(--radius-md);
    background: var(--accent-soft);
  }

  :global(.chat-log .resume-gate-title) {
    margin: 0;
    color: var(--heading);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.012em;
  }

  :global(.chat-log .resume-gate-button) {
    display: inline-flex;
    min-height: 2.65rem;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    overflow: hidden;
    border: 1px solid var(--accent);
    border-radius: var(--radius-sm);
    background: var(--accent);
    color: var(--accent-contrast);
    font-family: var(--font-body);
    font-size: 0.76rem;
    font-weight: 500;
    line-height: 1.3;
    white-space: nowrap;
    cursor: pointer;
    transition: background-color var(--duration-default) var(--ease), transform var(--duration-default) var(--spring);
  }

  :global(.chat-log .resume-gate-button:disabled) {
    opacity: 0.68;
    cursor: wait;
  }

  :global(.chat-log .resume-gate-button[data-state='downloaded']) {
    opacity: 1;
    cursor: default;
  }

  :global(html.pointer-moved .chat-log .resume-gate-button:not(:disabled):hover) {
    background: color-mix(in oklab, var(--accent) 88%, var(--ink));
    transform: translateY(-1px);
  }

  :global(.chat-log .resume-download-button) {
    width: 100%;
    margin-top: var(--space-1);
  }

  :global(.chat-log .resume-download-button[data-state='downloaded']) {
    animation: resume-download-settle var(--duration-default) var(--ease) both;
  }

  :global(.chat-log .resume-download-check) {
    display: inline-grid;
    width: var(--space-5);
    height: var(--space-5);
    place-items: center;
    border-radius: var(--radius-pill);
    background: var(--accent-contrast);
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
    animation: resume-check-in var(--duration-default) var(--spring) both;
  }

  :global(.chat-log .resume-gate-status) {
    margin: 0;
    font-size: 0.68rem;
    line-height: 1.5;
    color: var(--error);
  }

  :global(.chat-log .resume-gate-status[hidden]) {
    display: none;
  }

  @keyframes resume-download-settle {
    0% { transform: scale(1); }
    45% { transform: scale(1.015); }
    100% { transform: scale(1); }
  }

  @keyframes resume-check-in {
    from {
      opacity: 0;
      transform: scale(0.6) rotate(-12deg);
    }
    to {
      opacity: 1;
      transform: scale(1) rotate(0);
    }
  }

  /* --- Floating pills (stop / jump) ----------------------------------------- */

  /* A zero-height row whose pill is lifted up over the log. */
  .chat-float {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    gap: var(--space-2);
    height: 0;
  }

  /* While a pill is showing, fade the log out underneath it so transcript text
     never visually threads through the pill row. */
  .chat-float::before {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 3.6rem;
    background: linear-gradient(to top, var(--paper-raised) 35%, transparent);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-default) var(--ease);
  }

  .chat-float:has(.chat-pill:not([hidden]))::before {
    opacity: 1;
  }

  /* An always-on, shallower fade keeps the transcript's last line from
     sitting flush against the composer zone — one surface, softly settled. */
  .chat-float::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 1.1rem;
    background: linear-gradient(to top, var(--paper-raised), transparent);
    pointer-events: none;
  }

  .chat-pill {
    position: relative;
    display: inline-flex;
    transform: translateY(calc(-100% - var(--space-3)));
    align-items: center;
    gap: 0.35rem;
    padding: 0.34rem 0.75rem;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-pill);
    background: var(--paper-raised);
    box-shadow: var(--shadow-small);
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.02em;
    white-space: nowrap;
    cursor: pointer;
    transition: color var(--duration-default) var(--ease), border-color var(--duration-default) var(--ease);
  }

  .chat-pill[hidden] {
    display: none;
  }

  .chat-pill svg {
    width: 0.7rem;
    height: 0.7rem;
  }

  :global(html.pointer-moved) .chat-pill:hover {
    color: var(--heading);
    border-color: var(--ink-muted);
  }

  /* --- Composer -------------------------------------------------------------- */

  .chat-notice {
    margin: 0 var(--space-5) var(--space-2);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    background: color-mix(in oklab, var(--warning) 12%, var(--paper-raised));
    color: var(--warning-ink);
    font-size: 0.76rem;
    line-height: 1.4;
  }

  .chat-notice[hidden] {
    display: none;
  }

  /* Quiet character counter — appears only once the input crosses ~85% of
     the 2000-character cap (aria-hidden: the input hint already states the
     limit for assistive tech). */
  .chat-count {
    margin: 0 var(--space-5) var(--space-1);
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.02em;
    text-align: right;
  }

  .chat-count[hidden] {
    display: none;
  }

  /* One quiet composer surface: the send action is inset into the field so it
     reads as part of the message action, not as a second floating control. */
  .chat-form {
    padding: var(--space-2) var(--space-4) var(--space-4);
  }

  .chat-composer {
    position: relative;
    display: flex;
    min-height: 2.75rem;
    align-items: flex-end;
    overflow: hidden;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    background: var(--surface);
    transition: border-color var(--duration-default) var(--ease);
  }

  .chat-composer:focus-within {
    border-color: color-mix(in oklab, var(--accent) 60%, var(--hairline));
  }

  .chat-input {
    width: 100%;
    /* ~4 lines of 0.86rem/1.5 text plus padding; past that the field scrolls. */
    max-height: 6.1rem;
    padding: 0.65rem 3.25rem 0.65rem 0.8rem;
    resize: none;
    overflow-y: auto;
    scrollbar-width: none;
    border: 0;
    background: transparent;
    color: var(--ink);
    font-family: inherit;
    font-size: 0.86rem;
    line-height: 1.5;
  }

  .chat-input::-webkit-scrollbar {
    display: none;
  }

  .chat-input:focus-visible {
    outline: none;
  }

  .chat-input::placeholder {
    color: var(--ink-muted);
  }

  .chat-input:disabled {
    opacity: 0.6;
  }

  .chat-send {
    position: absolute;
    right: var(--space-1);
    bottom: var(--space-1);
    display: grid;
    width: 2.25rem;
    aspect-ratio: 1;
    place-items: center;
    padding: 0;
    border: 1px solid var(--accent);
    border-radius: 50%;
    background: var(--accent);
    color: var(--accent-contrast);
    cursor: pointer;
    transition:
      background-color var(--duration-default) var(--ease),
      border-color var(--duration-default) var(--ease),
      color var(--duration-default) var(--ease),
      transform var(--duration-default) var(--spring);
  }

  .chat-send-arrow {
    display: block;
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 1;
  }

  .chat-send:disabled {
    border-color: transparent;
    background: color-mix(in oklab, var(--ink-muted) 14%, var(--surface));
    color: color-mix(in oklab, var(--ink-muted) 72%, var(--hairline));
    cursor: default;
  }

  :global(html.pointer-moved) .chat-send:not(:disabled):hover {
    transform: translateY(-1px);
  }

  .chat-send:not(:disabled):active {
    transform: scale(0.96);
  }

  /* Fullscreen sheet on phones — including landscape, where the height (not
     the width) is what runs out.

     Researched iOS pattern: the sheet is plain fixed-position CSS sized with
     dvh (vh fallback first, so the cascade degrades cleanly on old engines).
     No JS chases the browser toolbar — the body lock in chat.ts freezes the
     page, which freezes the iOS toolbar, which keeps 100dvh stable. Internal
     layout is a grid whose messages row (1fr, min-height 0) is the only thing
     that scrolls; the software keyboard lifts the composer cluster via the
     --kb inset that chat.ts maintains from the visualViewport while the sheet
     is open. */
  @media (max-width: 30rem), (max-height: 30rem) {
    .chat-panel {
      inset: 0;
      width: 100%;
      max-height: none;
      height: 100vh;
      height: 100dvh;
      display: grid;
      /* header / messages / (announcer, pills, notice, count, form, footer —
         implicit auto rows). Only the 1fr messages row flexes. */
      grid-template-rows: auto 1fr auto;
      border: none;
      border-radius: 0;
      overscroll-behavior: none;
      transform-origin: 50% 100%;
    }

    .chat-panel:not(.is-open) {
      transform: translate3d(0, var(--space-6), 0);
    }

    .chat-body {
      min-height: 0;
      overscroll-behavior: contain;
      /* Momentum scrolling in the log on iOS. */
      -webkit-overflow-scrolling: touch;
    }

    /* iOS safe areas: keep the header clear of the notch and the composer
       cluster clear of the home indicator. */
    .chat-header {
      padding-top: calc(var(--space-4) + env(safe-area-inset-top));
      padding-left: calc(var(--space-5) + env(safe-area-inset-left));
      padding-right: calc(var(--space-5) + env(safe-area-inset-right));
    }

    /* The form is the last row of the composer cluster, so it carries the
       keyboard inset (lifting itself above the keyboard) and the
       home-indicator safe area. */
    .chat-form {
      padding-left: calc(var(--space-4) + env(safe-area-inset-left));
      padding-right: calc(var(--space-4) + env(safe-area-inset-right));
      margin-bottom: var(--kb, 0px);
      padding-bottom: max(0.75rem, env(safe-area-inset-bottom));
    }

    /* ≥16px so iOS Safari does not zoom the page when the input focuses. */
    .chat-input {
      font-size: 1rem;
    }

  }

  @media (prefers-reduced-motion: reduce) {
    .chat-logo :global(.logo-piece),
    .chat-logo :global(.logo-piece path) {
      animation: none;
    }

    .chat-logo :global(path) {
      fill-opacity: 1;
      stroke: none;
    }

    .chat-panel,
    .chat-header,
    .chat-body,
    .chat-form,
    .chat-composer,
    .chat-close,
    .chat-send,
    .chat-pill,
    .chat-input,
    :global(.chat-log .resume-gate-button),
    :global(.chat-panel .chat-chip) {
      transition: none;
    }

    :global(.chat-log .resume-download-button[data-state='downloaded']),
    :global(.chat-log .resume-download-check) {
      animation: none;
    }

    .chat-panel:not(.is-open) {
      transform: none;
    }

    .chat-panel:not(.is-open) .chat-header,
    .chat-panel:not(.is-open) .chat-body,
    .chat-panel:not(.is-open) .chat-form {
      transform: none;
    }

    :global(html.pointer-moved) .chat-send:not(:disabled):hover {
      transform: none;
    }
  }
</style>

<style is:global>
  /* Typing indicator + reveal cascade. These elements are all created at
     runtime by chat.ts, and their @keyframes must keep their literal names
     (Astro scoping would rename them out from under the runtime-added
     classes), so this block is global with prefixed keyframe names. */

  /* Three ink-muted dots on the flat assistant style, staggered through a
     1.2s iMessage-style bounce/fade loop. */
  .chat-log .chat-bubble.chat-typing {
    display: flex;
    align-items: center;
    gap: 0.32rem;
    /* Roughly one line of reply text, so the indicator→reply swap sits still. */
    min-height: 1.4rem;
  }

  .chat-typing .chat-typing-dot {
    width: 0.44rem;
    height: 0.44rem;
    border-radius: 50%;
    background: var(--ink-muted);
    animation: jrb-chat-typing-bounce 1.2s ease-in-out infinite;
  }

  .chat-typing .chat-typing-dot:nth-child(2) {
    animation-delay: 150ms;
  }

  .chat-typing .chat-typing-dot:nth-child(3) {
    animation-delay: 300ms;
  }

  @keyframes jrb-chat-typing-bounce {
    0%,
    55%,
    100% {
      transform: none;
      opacity: 0.4;
    }
    25% {
      transform: translateY(-0.26rem);
      opacity: 1;
    }
  }

  /* Reveal cascade: chat.ts adds .chat-reveal plus a per-block
     animation-delay (70ms stagger, capped) to each rendered block, then
     removes both on animationend. `both` keeps delayed blocks invisible
     until their turn. */
  .chat-log .chat-reveal {
    animation: jrb-chat-reveal-in 140ms var(--ease) both;
  }

  @keyframes jrb-chat-reveal-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    /* Static dots with a gentle opacity pulse — no movement. */
    .chat-typing .chat-typing-dot {
      animation: jrb-chat-typing-pulse 1.6s ease-in-out infinite;
    }

    @keyframes jrb-chat-typing-pulse {
      0%,
      100% {
        opacity: 0.35;
      }
      50% {
        opacity: 0.8;
      }
    }

    /* Belt and suspenders: chat.ts already skips the cascade classes under
       reduced motion. */
    .chat-log .chat-reveal {
      animation: none;
    }
  }
</style>
