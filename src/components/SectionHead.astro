---
interface Props {
  id: string;
  label: string;
  title: string;
  description?: string;
}

const { id, label, title, description } = Astro.props;
---

<header class="section-head reveal">
  <p class="section-label serif">{label}</p>
  <h2 id={id}>{title}</h2>
  {description && <p class="section-description">{description}</p>}
</header>

<style>
  .section-head {
    display: grid;
    grid-template-columns: minmax(7rem, 0.35fr) 1fr;
    column-gap: var(--space-8);
    row-gap: var(--space-3);
    margin-bottom: var(--space-12);
    scroll-margin-top: var(--space-24);
  }

  .section-label {
    padding-top: var(--space-2);
    color: var(--accent);
    font-size: 1.1rem;
  }

  h2 {
    max-width: 18ch;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .section-description {
    grid-column: 2;
    max-width: 38rem;
    color: var(--ink-muted);
    font-size: 1.05rem;
    line-height: 1.65;
    text-wrap: pretty;
  }

  @media (max-width: 40rem) {
    .section-head {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .section-label,
    .section-description {
      grid-column: 1;
    }
  }
</style>
