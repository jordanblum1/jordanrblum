---
import { storyBeats } from '../data/site';
import MarketplaceNote from './story/MarketplaceNote.astro';
import AgentTrace from './story/AgentTrace.astro';
import ProductSurface from './story/ProductSurface.astro';
import EvalNotes from './story/EvalNotes.astro';

const visuals = {
  marketplace: MarketplaceNote,
  agent: AgentTrace,
  product: ProductSurface,
  evals: EvalNotes,
} as const;
---

<section class="story-shell" aria-labelledby="roam-story-title">
  <header class="story-intro">
    <p class="mono-meta"><a class="roam-link" href="https://www.withroam.com" target="_blank" rel="noopener">Roam ↗</a> · 2025—now</p>
    <h2 id="roam-story-title">A job with two parts.</h2>
  </header>

  <div class="story-track" data-beats={storyBeats.length}>
    <div class="story-stage">
      {storyBeats.map((beat, index) => {
        const Visual = visuals[beat.visual];
        const titleId = `story-beat-${index}`;

        return (
          <article class="story-beat" data-story-beat={index} aria-labelledby={titleId}>
            <div class="beat-sentence" data-beat={index}>
              <p class="beat-era mono-meta">{beat.era}</p>
              <h3 id={titleId}>{beat.title}</h3>
              <p class="beat-copy">{beat.sentence}</p>
            </div>

            <div class="beat-visual" data-visual={index}>
              <Visual />
            </div>
          </article>
        );
      })}
    </div>

    <div class="story-spacers" aria-hidden="true">
      {storyBeats.map(() => <div class="story-spacer"></div>)}
    </div>
  </div>
</section>

<script src="../scripts/story.ts"></script>

<style>
  .story-shell {
    max-width: 100%;
  }

  .story-intro {
    display: grid;
    gap: var(--space-3);
    max-width: 660px;
    padding-bottom: clamp(var(--space-16), 10vw, var(--space-32));
  }

  .story-intro h2 {
    max-width: 12ch;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 450;
    font-size: clamp(38px, 6vw, 64px);
    line-height: 1.02;
    letter-spacing: -0.035em;
  }

  .roam-link {
    color: var(--heading);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--accent) 42%, transparent);
    text-underline-offset: 0.25em;
  }

  .story-stage {
    display: grid;
  }

  .story-spacers {
    display: none;
  }

  .story-beat {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(360px, 1.22fr);
    gap: clamp(var(--space-8), 7vw, var(--space-24));
    min-height: 82vh;
  }

  .beat-sentence,
  .beat-visual {
    align-self: start;
  }

  .beat-sentence {
    display: grid;
    gap: var(--space-3);
    max-width: 31rem;
  }

  .beat-sentence h3 {
    max-width: 15ch;
    font-size: clamp(28px, 3.6vw, 44px);
    line-height: 1.08;
    letter-spacing: -0.025em;
  }

  .beat-era {
    color: var(--accent);
  }

  .beat-copy {
    max-width: 37ch;
    font-size: clamp(16px, 1.55vw, 19px);
    line-height: 1.55;
    color: var(--ink-75);
  }

  .beat-visual {
    display: grid;
    place-items: center;
    min-width: 0;
  }

  @media (min-width: 721px) {
    .story-track.is-enhanced {
      position: relative;
    }

    .story-track.is-enhanced .story-stage {
      position: sticky;
      top: 0;
      height: 100vh;
      overflow: clip;
    }

    .story-track.is-enhanced .story-beat {
      position: absolute;
      inset: 0;
      align-items: center;
      min-height: 0;
    }

    .story-track.is-enhanced .beat-sentence,
    .story-track.is-enhanced .beat-visual {
      align-self: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--duration-default) var(--ease);
    }

    .story-track.is-enhanced .story-beat.is-active .beat-sentence,
    .story-track.is-enhanced .story-beat.is-active .beat-visual,
    .story-track.is-enhanced .beat-sentence.active,
    .story-track.is-enhanced .beat-visual.active {
      opacity: 1;
    }

    .story-track.is-enhanced .story-spacers {
      display: block;
    }

    .story-track.is-enhanced .story-spacer {
      height: 80vh;
    }
  }

  @media (max-width: 720px) {
    .story-intro {
      padding-bottom: var(--space-16);
    }

    .story-beat {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--space-8);
      min-height: 0;
      padding-bottom: var(--space-24);
    }

    .story-beat:last-child {
      padding-bottom: 0;
    }

    .beat-sentence {
      gap: var(--space-2);
    }

    .beat-sentence h3 {
      font-size: clamp(30px, 9vw, 40px);
    }

    .beat-copy {
      max-width: 34rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .story-track.is-enhanced .beat-sentence,
    .story-track.is-enhanced .beat-visual {
      transition: opacity var(--duration-fast) var(--ease);
    }
  }
</style>
