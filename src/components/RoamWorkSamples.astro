---
import { Image } from 'astro:assets';
import agentHarnessChat from '../assets/experience/agent-harness-chat.png';
import agentHarnessSubagents from '../assets/experience/agent-harness-subagents.png';
import reedChat from '../assets/experience/reed-chat.jpg';
import reedHome from '../assets/experience/reed-home.jpg';
import roamListing from '../assets/experience/roam-listing.jpg';
import roamMarketplace from '../assets/experience/roam-marketplace.jpg';

interface Props {
  group: 'roam-marketplace' | 'reed' | 'agent-harness';
}

const { group } = Astro.props;

const groups = [
  {
    id: 'roam-marketplace',
    title: 'Roam marketplace',
    description: 'Map search and the home-detail flow.',
    shots: [
      {
        src: roamMarketplace,
        label: 'Map search',
        alt: "Roam's public home search with a map, buyer filters, and listing cards",
      },
      {
        src: roamListing,
        label: 'Listing detail',
        alt: "A Roam home listing with its photo gallery, address, and price",
      },
    ],
  },
  {
    id: 'reed',
    title: 'Reed',
    description: 'The public starting point and a guided buyer conversation.',
    shots: [
      {
        src: reedHome,
        label: 'Homepage',
        alt: "Reed's public homepage introducing its AI real estate expert",
      },
      {
        src: reedChat,
        label: 'Buyer chat',
        alt: "Reed's buyer chat offering paths to explore areas, find homes, inspect a home, or make an offer",
      },
    ],
  },
  {
    id: 'agent-harness',
    title: 'Agent harness',
    description: 'Chat and sub-agent supervision with synthetic demo data.',
    shots: [
      {
        src: agentHarnessChat,
        label: 'Chat',
        alt: 'A synthetic agent-harness chat showing an orchestrator coordinating a product review',
      },
      {
        src: agentHarnessSubagents,
        label: 'Sub-agents',
        alt: 'A synthetic agent-harness graph showing an orchestrator supervising four parallel sub-agents',
      },
    ],
  },
];

const selectedGroup = groups.find((item) => item.id === group);

if (!selectedGroup) {
  throw new Error(`Unknown Roam work-sample group: ${group}`);
}
---

<section class="work-samples" data-roam-sample={selectedGroup.id} aria-label={`${selectedGroup.title} screens`}>
  <p class="work-sample-description mono-meta">{selectedGroup.description}</p>
  <div class="media-pair">
    {selectedGroup.shots.map((shot) => (
      <figure class="media-shot">
        <div class="media-frame">
          <Image
            src={shot.src}
            alt={shot.alt}
            loading="lazy"
            widths={[360, 480, 640, 960, 1440]}
            sizes="(max-width: 48rem) calc(100vw - 64px), min(30rem, 38vw)"
          />
        </div>
        <figcaption class="shot-label mono-meta">{shot.label}</figcaption>
      </figure>
    ))}
  </div>
</section>

<style>
  .work-samples {
    container-type: inline-size;
    grid-column: 1 / -1;
    min-width: 0;
    padding-top: var(--space-6);
    border-top: 1px solid var(--hairline);
  }

  .work-sample-description {
    margin-bottom: var(--space-4);
    color: var(--ink-muted);
  }

  .media-pair {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
    align-items: start;
    min-width: 0;
  }

  .media-shot {
    display: grid;
    gap: var(--space-2);
    min-width: 0;
    margin: 0;
  }

  .media-frame {
    overflow: hidden;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    background: white;
    box-shadow: var(--shadow-small);
  }

  .media-frame :global(img) {
    display: block;
    width: 100%;
    height: auto;
    filter: none;
  }

  .shot-label {
    color: var(--ink-muted);
    font-size: 0.6875rem;
    line-height: 1.4;
  }

  @container (max-width: 30rem) {
    .media-pair {
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-auto-columns: calc(100% - var(--space-8));
      overflow-x: auto;
      overscroll-behavior-inline: contain;
      padding-bottom: var(--space-2);
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }

    .media-pair::-webkit-scrollbar {
      display: none;
    }

    .media-shot {
      scroll-snap-align: start;
    }
  }
</style>
