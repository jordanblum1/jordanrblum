---
import { Image } from 'astro:assets';
import agentHarnessChat from '../assets/experience/agent-harness-chat.png';
import agentHarnessSubagents from '../assets/experience/agent-harness-subagents.png';
import reedChat from '../assets/experience/reed-chat.jpg';
import reedHome from '../assets/experience/reed-home.jpg';
import roamListing from '../assets/experience/roam-listing.jpg';
import roamMarketplace from '../assets/experience/roam-marketplace.jpg';

const groups = [
  {
    id: 'roam-marketplace',
    title: 'Roam marketplace',
    description: 'Map search and the home-detail flow.',
    shots: [
      {
        src: roamMarketplace,
        label: 'Map search',
        alt: "Roam's public home search with a map, buyer filters, and listing cards",
      },
      {
        src: roamListing,
        label: 'Listing detail',
        alt: "A Roam home listing with its photo gallery, address, and price",
      },
    ],
  },
  {
    id: 'reed',
    title: 'Reed',
    description: 'The public starting point and a guided buyer conversation.',
    shots: [
      {
        src: reedHome,
        label: 'Homepage',
        alt: "Reed's public homepage introducing its AI real estate expert",
      },
      {
        src: reedChat,
        label: 'Buyer chat',
        alt: "Reed's buyer chat offering paths to explore areas, find homes, inspect a home, or make an offer",
      },
    ],
  },
  {
    id: 'agent-harness',
    title: 'Agent harness',
    description: 'Chat and sub-agent supervision with synthetic demo data.',
    shots: [
      {
        src: agentHarnessChat,
        label: 'Chat',
        alt: 'A synthetic agent-harness chat showing an orchestrator coordinating a product review',
      },
      {
        src: agentHarnessSubagents,
        label: 'Sub-agents',
        alt: 'A synthetic agent-harness graph showing an orchestrator supervising four parallel sub-agents',
      },
    ],
  },
];
---

<details class="experience-media" data-roam-samples>
  <summary class="experience-media-summary">
    <span class="experience-media-summary-copy">
      <span class="experience-media-title">Selected work from Roam</span>
      <span class="experience-media-description">Marketplace, Reed, and the agent tooling behind them.</span>
    </span>
    <span class="experience-media-action mono-meta" aria-hidden="true">
      <span class="when-closed">View 6 screens</span>
      <span class="when-open">Hide screens</span>
      <svg class="experience-media-chevron" viewBox="0 0 16 16" fill="none">
        <path d="m3 6 5 5 5-5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </span>
  </summary>

  <div class="experience-media-panel">
    <div class="experience-media-panel-inner">
      <div class="experience-media-grid">
        {groups.map((group) => (
          <article class="media-card" aria-labelledby={`${group.id}-title`}>
            <header class="media-caption">
              <h5 id={`${group.id}-title`}>{group.title}</h5>
              <p>{group.description}</p>
            </header>

            <div class="media-pair">
              {group.shots.map((shot) => (
                <figure class="media-shot">
                  <div class="media-frame">
                    <Image
                      src={shot.src}
                      alt={shot.alt}
                      loading="lazy"
                      widths={[360, 480, 640, 960, 1440]}
                      sizes="(max-width: 48rem) calc(100vw - 32px), min(30rem, 38vw)"
                    />
                  </div>
                  <figcaption class="shot-label mono-meta">{shot.label}</figcaption>
                </figure>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</details>

<style>
  .experience-media {
    grid-column: 1 / -1;
    margin-top: var(--space-4);
    border-top: 1px solid var(--hairline);
  }

  .experience-media-summary {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    min-height: var(--space-16);
    gap: var(--space-6);
    align-items: center;
    padding: var(--space-4);
    border-radius: var(--radius-md);
    cursor: pointer;
    list-style: none;
    transition: background-color var(--duration-default) var(--ease);
  }

  .experience-media-summary::marker,
  .experience-media-summary::-webkit-details-marker {
    display: none;
    content: '';
  }

  .experience-media-summary-copy {
    display: grid;
    gap: var(--space-2);
    max-width: var(--measure);
  }

  .experience-media-title {
    color: var(--heading);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.25;
  }

  .experience-media-description {
    color: var(--ink-muted);
    font-size: 0.8125rem;
    line-height: 1.5;
    text-wrap: pretty;
  }

  .experience-media-action {
    display: inline-flex;
    gap: var(--space-2);
    align-items: center;
    color: var(--accent);
    white-space: nowrap;
  }

  .experience-media-chevron {
    display: block;
    width: var(--space-4);
    height: var(--space-4);
    transition: transform var(--duration-default) var(--ease);
  }

  .when-open,
  .experience-media[open] .when-closed {
    display: none;
  }

  .experience-media[open] .when-open {
    display: inline;
  }

  .experience-media[open] .experience-media-chevron {
    transform: rotate(180deg);
  }

  .experience-media > .experience-media-panel {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows var(--duration-slow) var(--ease),
      opacity var(--duration-default) var(--ease);
  }

  .experience-media[open] > .experience-media-panel {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .experience-media-panel-inner {
    min-height: 0;
    overflow: hidden;
  }

  .experience-media-grid {
    display: grid;
    border-top: 1px solid var(--hairline);
  }

  .media-card {
    display: grid;
    grid-template-columns: minmax(9rem, 12rem) minmax(0, 1fr);
    gap: var(--space-6);
    align-items: start;
    min-width: 0;
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--hairline);
  }

  .media-caption {
    display: grid;
    gap: var(--space-2);
    padding-top: var(--space-1);
  }

  .media-caption h5 {
    margin: 0;
    color: var(--heading);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.25;
  }

  .media-caption p {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.8125rem;
    line-height: 1.5;
    text-wrap: pretty;
  }

  .media-pair {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
    align-items: start;
    min-width: 0;
  }

  .media-shot {
    display: grid;
    gap: var(--space-2);
    min-width: 0;
    margin: 0;
  }

  .media-frame {
    overflow: hidden;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    background: white;
    box-shadow: var(--shadow-small);
  }

  .media-frame :global(img) {
    display: block;
    width: 100%;
    height: auto;
    filter: none;
  }

  .shot-label {
    color: var(--ink-muted);
    font-size: 0.6875rem;
    line-height: 1.4;
  }

  @media (hover: hover) and (pointer: fine) {
    .experience-media-summary:hover {
      background: var(--hover-fill);
    }
  }

  @media (max-width: 48rem) {
    .experience-media-summary {
      gap: var(--space-4);
      padding-inline: var(--space-2);
    }

    .experience-media-action {
      font-size: 0.6875rem;
    }

    .media-card {
      grid-template-columns: 1fr;
      gap: var(--space-4);
      padding-block: var(--space-8);
    }

    .media-pair {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .experience-media-chevron,
    .experience-media > .experience-media-panel {
      transition: none;
    }
  }
</style>
