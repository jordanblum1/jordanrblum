---
// A representative trace, not a screenshot or a transcript of production data.
---

<div
  class="agent-trace"
  role="img"
  aria-label="AI agent trace showing a request moving through search, loan analysis, and response drafting tools"
>
  <div aria-hidden="true">
    <header class="trace-header">
      <div class="window-dots"><i></i><i></i><i></i></div>
      <p class="mono-meta">reed / trace</p>
      <p class="trace-state mono-meta">complete</p>
    </header>

    <div class="trace-prompt">
      <span class="mono-meta">REQUEST</span>
      <p>“Show me homes where the loan changes the math.”</p>
    </div>

    <ol class="trace-events">
      <li>
        <span class="event-mark"></span>
        <div>
          <p><code>search_listings</code><span class="event-state">done</span></p>
          <small>location · budget · loan type</small>
        </div>
      </li>
      <li>
        <span class="event-mark"></span>
        <div>
          <p><code>compare_payments</code><span class="event-state">done</span></p>
          <small>assumption · cash needed · monthly cost</small>
        </div>
      </li>
      <li>
        <span class="event-mark"></span>
        <div>
          <p><code>draft_answer</code><span class="event-state">done</span></p>
          <small>grounded in listing + loan details</small>
        </div>
      </li>
    </ol>

    <footer class="trace-footer mono-meta">
      <span>tools 03</span>
      <span>handoff ready</span>
    </footer>
  </div>
</div>

<style>
  .agent-trace {
    width: min(100%, 590px);
    overflow: hidden;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-sm);
    background: color-mix(in oklab, var(--heading) 3%, var(--surface));
  }

  .trace-header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-4);
    min-height: 44px;
    padding: 0 var(--space-4);
    border-bottom: 1px solid var(--hairline);
  }

  .trace-header > p {
    font-size: 11px;
  }

  .window-dots {
    display: flex;
    gap: var(--space-1);
  }

  .window-dots i {
    width: 7px;
    height: 7px;
    border: 1px solid var(--ink-75);
    border-radius: 50%;
  }

  .trace-state {
    justify-self: end;
    color: var(--accent);
  }

  .trace-prompt {
    display: grid;
    gap: var(--space-2);
    padding: clamp(var(--space-6), 4vw, var(--space-8));
    border-bottom: 1px solid var(--hairline);
  }

  .trace-prompt span {
    font-size: 10px;
    color: var(--accent);
  }

  .trace-prompt p {
    max-width: 38ch;
    font-family: var(--font-display);
    font-size: clamp(20px, 3vw, 28px);
    line-height: 1.18;
    color: var(--heading);
  }

  .trace-events {
    margin: 0;
    padding: var(--space-3) clamp(var(--space-6), 4vw, var(--space-8));
    list-style: none;
  }

  .trace-events li {
    display: grid;
    grid-template-columns: 14px minmax(0, 1fr);
    gap: var(--space-3);
    padding: var(--space-3) 0;
  }

  .event-mark {
    position: relative;
    width: 7px;
    height: 7px;
    margin-top: var(--space-2);
    border: 1px solid var(--accent);
    border-radius: 50%;
  }

  .event-mark::after {
    position: absolute;
    top: 9px;
    left: 2px;
    width: 1px;
    height: 44px;
    background: var(--hairline);
    content: '';
  }

  .trace-events li:last-child .event-mark::after {
    display: none;
  }

  .trace-events li > div {
    display: grid;
    gap: var(--space-1);
  }

  .trace-events p {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .trace-events code,
  .trace-events small,
  .event-state {
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .trace-events code {
    color: var(--heading);
  }

  .trace-events small,
  .event-state {
    color: var(--ink-75);
  }

  .event-state {
    flex: none;
    color: var(--accent);
  }

  .trace-footer {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3) clamp(var(--space-6), 4vw, var(--space-8));
    border-top: 1px solid var(--hairline);
    font-size: 11px;
  }
</style>
