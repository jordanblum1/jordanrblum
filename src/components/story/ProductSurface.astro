---
// A small, representative Reed surface rather than a literal production screenshot.
---

<div
  class="product-surface"
  role="img"
  aria-label="AI realtor product surface pairing a conversational answer with a home and loan summary"
>
  <div aria-hidden="true">
    <header class="surface-header">
      <p class="surface-name">Reed</p>
      <p class="mono-meta">buyer workspace</p>
    </header>

    <div class="surface-body">
      <section class="conversation">
        <p class="message question">Which one actually fits my monthly budget?</p>
        <div class="message answer">
          <span class="answer-mark">R</span>
          <p>The assumable loan makes this one worth a closer look. I laid out the tradeoffs.</p>
        </div>
      </section>

      <article class="home-card">
        <div class="home-image">
          <svg viewBox="0 0 240 112" aria-hidden="true">
            <path d="M49 77 91 41l43 36M60 70v28h62V67M102 98V79h13v19" />
            <path d="M152 40h42M152 56h31M152 72h23" />
          </svg>
          <span class="mono-meta">saved</span>
        </div>
        <div class="home-details">
          <div>
            <p class="home-title">A home with a different equation</p>
            <p class="mono-meta">assumable loan · payment modeled</p>
          </div>
          <span class="surface-action">Review the numbers</span>
        </div>
      </article>
    </div>
  </div>
</div>

<style>
  .product-surface {
    width: min(100%, 620px);
    overflow: hidden;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-sm);
    background: var(--surface);
  }

  .surface-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-6);
    padding: var(--space-4) clamp(var(--space-4), 4vw, var(--space-8));
    border-bottom: 1px solid var(--hairline);
  }

  .surface-name {
    font-family: var(--font-display);
    font-size: 21px;
    font-style: italic;
    color: var(--heading);
  }

  .surface-header .mono-meta {
    font-size: 10px;
  }

  .surface-body {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(230px, 1.18fr);
    min-height: 360px;
  }

  .conversation {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    justify-content: center;
    padding: clamp(var(--space-4), 4vw, var(--space-8));
    border-right: 1px solid var(--hairline);
  }

  .message {
    font-size: 13px;
    line-height: 1.45;
  }

  .question {
    align-self: end;
    max-width: 21ch;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-sm) var(--radius-sm) var(--radius-xs) var(--radius-sm);
    color: var(--heading);
  }

  .answer {
    display: grid;
    grid-template-columns: 24px minmax(0, 1fr);
    gap: var(--space-2);
    max-width: 26ch;
    color: var(--ink-75);
  }

  .answer-mark {
    display: grid;
    place-items: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--accent);
    font-family: var(--font-display);
    font-size: 13px;
    font-style: italic;
    color: var(--surface);
  }

  .home-card {
    display: grid;
    grid-template-rows: minmax(180px, 1fr) auto;
    margin: clamp(var(--space-4), 4vw, var(--space-8));
    border: 1px solid var(--hairline);
  }

  .home-image {
    position: relative;
    display: grid;
    place-items: center;
    overflow: hidden;
    background: var(--hover-fill);
  }

  .home-image svg {
    width: 82%;
    color: var(--ink-75);
  }

  .home-image path {
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .home-image span {
    position: absolute;
    top: 12px;
    right: 12px;
    color: var(--accent);
  }

  .home-details {
    display: grid;
    gap: var(--space-4);
    padding: var(--space-4);
    border-top: 1px solid var(--hairline);
  }

  .home-title {
    margin-bottom: var(--space-1);
    font-size: 14px;
    font-weight: 500;
    color: var(--heading);
  }

  .home-details .mono-meta {
    font-size: 9px;
  }

  .surface-action {
    display: block;
    width: 100%;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--accent);
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    text-align: center;
    color: var(--accent);
  }

  @media (max-width: 520px) {
    .surface-body {
      grid-template-columns: minmax(0, 1fr);
    }

    .conversation {
      min-height: 230px;
      border-right: 0;
      border-bottom: 1px solid var(--hairline);
    }

    .home-card {
      min-height: 330px;
    }
  }
</style>
