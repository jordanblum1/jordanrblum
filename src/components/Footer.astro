---
import { social } from '../data/site';
---

<footer>
  <div class="wide footer-inner">
    <p class="footer-note">If any of this sounds useful, <a class="text-link" href="mailto:jordanblum16@gmail.com">send me a note</a>.</p>
    <nav class="social mono-meta" aria-label="Elsewhere">
      {social.map((item) => (
        <a
          href={item.href}
          target={item.href.startsWith('http') ? '_blank' : undefined}
          rel={item.href.startsWith('http') ? 'noopener' : undefined}
        >
          {item.label}<span aria-hidden="true">↗</span>
        </a>
      ))}
    </nav>
    <div class="colophon mono-meta">
      <span>Made in New York · © {new Date().getFullYear()} Jordan Blum</span>
      <span>Astro · Fraunces · Switzer · Geist Mono</span>
    </div>
  </div>
</footer>

<style>
  footer {
    padding-block: var(--space-24) var(--space-8);
  }

  .footer-inner {
    border-top: 1px solid var(--hairline);
    padding-top: var(--space-12);
  }

  .footer-note {
    max-width: 18ch;
    color: var(--heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.035em;
    text-wrap: balance;
  }

  .social {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-8);
    margin-block: var(--space-16);
  }

  .social a {
    display: inline-flex;
    gap: var(--space-2);
    color: var(--ink-muted);
    transition: color var(--duration-default) var(--ease);
  }

  html.pointer-moved .social a:hover {
    color: var(--accent);
  }

  .colophon {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-3);
    padding-top: var(--space-6);
    border-top: 1px solid var(--hairline);
  }
</style>
