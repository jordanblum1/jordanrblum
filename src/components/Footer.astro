---
import { social } from '../data/site';
import blumMarkSource from '../assets/identity/blum-mark.svg?raw';

const [email, linkedin, github, blumblumblum] = social;
const blumMark = blumMarkSource
  .replace(/<\?xml[^>]*>\s*/, '')
  .replace(/<defs>[\s\S]*?<\/defs>/, '')
  .replace(/\s+id="Layer_\d+"/g, '');
---

<footer>
  <div class="wide footer-inner">
    <div class="footer-lead">
      <p class="footer-title">Want to chat?</p>
      <div class="footer-cta-group">
        <button type="button" class="chat-cta" data-footer-chat-cta>
          <span>Chat with my assistant</span>
          <span aria-hidden="true">→</span>
        </button>
        <a class="email-link" href={email.href}>
          <span>Email me</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <nav class="social" aria-label="Contact and professional profiles">
      <a href={email.href} aria-label="Email Jordan" title="Email">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3.75 5.75h16.5v12.5H3.75z"></path>
          <path d="m4.5 6.5 7.5 6 7.5-6"></path>
        </svg>
      </a>
      <a href={linkedin.href} target="_blank" rel="noopener" aria-label="Jordan on LinkedIn" title="LinkedIn">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5.36 8.17H2.22V21h3.14V8.17ZM3.79 2A1.82 1.82 0 1 0 3.8 5.64 1.82 1.82 0 0 0 3.79 2ZM21 13.64c0-3.87-2.07-5.67-4.83-5.67a4.18 4.18 0 0 0-3.77 2.07h-.04V8.17h-3V21h3.13v-6.35c0-1.67.32-3.3 2.4-3.3 2.05 0 2.08 1.92 2.08 3.41V21H21v-7.36Z"></path>
        </svg>
      </a>
      <a href={github.href} target="_blank" rel="noopener" aria-label="Jordan on GitHub" title="GitHub">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.86c-2.78.61-3.37-1.18-3.37-1.18-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.9 1.53 2.35 1.09 2.92.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.03A9.5 9.5 0 0 1 12 6.84c.85 0 1.69.11 2.49.34 1.91-1.3 2.75-1.03 2.75-1.03.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.86V21c0 .27.18.58.69.48A10 10 0 0 0 12 2Z"></path>
        </svg>
      </a>
      <a class="blum-link" href={blumblumblum.href} target="_blank" rel="noopener" aria-label="Visit blumblumblum" title="blumblumblum">
        <span set:html={blumMark} aria-hidden="true"></span>
      </a>
    </nav>

    <div class="colophon">
      <span>© {new Date().getFullYear()} Jordan Blum</span>
      <span>New York</span>
    </div>
  </div>
</footer>

<script>
  // The floating widget owns its own open/close state; this CTA just triggers its
  // launcher so the footer doesn't need to duplicate that logic.
  const cta = document.querySelector<HTMLButtonElement>('[data-footer-chat-cta]');
  const launcher = document.querySelector<HTMLButtonElement>('[data-chat-launcher]');

  cta?.addEventListener('click', () => {
    if (launcher?.getAttribute('aria-expanded') !== 'true') launcher?.click();
  });
</script>

<style>
  footer {
    padding-block: var(--space-16) var(--space-8);
  }

  .footer-inner {
    padding-top: clamp(var(--space-16), 9vw, var(--space-24));
    border-top: 1px solid var(--hairline);
  }

  .footer-lead {
    display: flex;
    justify-content: space-between;
    gap: var(--space-8);
    align-items: end;
  }

  .footer-title {
    max-width: 12ch;
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: 500;
    line-height: 0.94;
    letter-spacing: -0.055em;
  }

  .footer-cta-group {
    display: flex;
    flex: 0 0 auto;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
  }

  .chat-cta,
  .email-link {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    gap: var(--space-8);
    padding: 0.9rem 1.15rem;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    background: var(--paper-raised);
    font-size: 0.88rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition:
      border-color var(--duration-default) var(--ease),
      background-color var(--duration-default) var(--ease),
      color var(--duration-default) var(--ease),
      transform 420ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .chat-cta {
    border-color: transparent;
    background: var(--accent);
    color: var(--accent-contrast);
  }

  /* Matches the widget launcher: no-JS visitors never see a CTA that can't do
     anything, so only the mailto fallback shows. */
  :global(html:not(.js)) .chat-cta {
    display: none;
  }

  .social {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-block: clamp(var(--space-16), 8vw, var(--space-24));
  }

  .social a {
    display: grid;
    width: 3.25rem;
    aspect-ratio: 1;
    place-items: center;
    border: 1px solid var(--hairline);
    border-radius: 50%;
    background: var(--paper-raised);
    color: var(--ink-muted);
    transition:
      color var(--duration-default) var(--ease),
      border-color var(--duration-default) var(--ease),
      transform 420ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .social svg {
    display: block;
    width: 1.18rem;
    height: 1.18rem;
    fill: currentColor;
  }

  .social a:first-child svg {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.5;
  }

  .social .blum-link {
    width: 5.75rem;
    aspect-ratio: auto;
    border-radius: 999px;
  }

  .blum-link > span,
  .blum-link :global(svg) {
    display: block;
    width: 3.8rem;
    height: auto;
  }

  .blum-link :global(path) {
    fill: var(--accent);
  }

  .colophon {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-3) var(--space-8);
    padding-top: var(--space-6);
    color: var(--ink-muted);
    border-top: 1px solid var(--hairline);
    font-family: var(--font-mono);
    font-size: 0.7rem;
  }

  :global(html.pointer-moved) .email-link:hover {
    border-color: var(--ink-muted);
    transform: translateY(-2px);
  }

  :global(html.pointer-moved) .chat-cta:hover {
    transform: translateY(-2px);
    opacity: 0.92;
  }

  :global(html.pointer-moved) .social a:hover {
    color: var(--heading);
    border-color: var(--accent);
    transform: translateY(calc(var(--space-1) * -1)) rotate(-2deg);
  }

  :global(html.pointer-moved) .social a:nth-child(even):hover {
    transform: translateY(calc(var(--space-1) * -1)) rotate(2deg);
  }

  @media (max-width: 38rem) {
    .footer-lead {
      align-items: start;
      flex-direction: column;
    }

    .footer-cta-group {
      flex-direction: column;
      align-items: start;
    }

    .footer-title {
      font-size: clamp(3.4rem, 17vw, 5.5rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .chat-cta,
    .email-link,
    .social a {
      transition: color 120ms, border-color 120ms;
    }

    :global(html.pointer-moved) .chat-cta:hover,
    :global(html.pointer-moved) .email-link:hover,
    :global(html.pointer-moved) .social a:hover,
    :global(html.pointer-moved) .social a:nth-child(even):hover {
      transform: none;
    }
  }
</style>
