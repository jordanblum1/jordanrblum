---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import HeroShowcase from '../components/HeroShowcase.astro';
import SelectedWork from '../components/SelectedWork.astro';
import ArchiveList from '../components/ArchiveList.astro';
import blumCollage from '../assets/identity/blum-collage.png';
import blumTagLogo from '../assets/identity/blum-tag-logo.png';
import { about, projectArchive, selectedWork } from '../data/site';
---

<Base
  title="Jordan Blum — Product Engineer in New York"
  description="Jordan Blum is a product engineer in New York who builds consumer products, developer platforms, AI tools, and oddly specific side projects."
>
  <main id="main-content" tabindex="-1">
    <HeroShowcase />

    <section class="work-section wide" id="work" aria-labelledby="work-heading">
      <header class="section-intro">
        <div>
          <h2 id="work-heading">A few things I’ve built and places I’ve worked.</h2>
        </div>
      </header>
      <SelectedWork items={selectedWork} />
    </section>

    <section class="more-section wide" aria-labelledby="more-heading">
      <header class="section-intro compact">
        <div>
          <h2 id="more-heading">More projects.</h2>
        </div>
      </header>
      <ArchiveList items={projectArchive} compact />
    </section>

    <section class="about-preview wide" aria-labelledby="about-preview-heading">
      <div class="about-copy">
        <h2 id="about-preview-heading">{about.title}</h2>
        <p>{about.paragraphs[0]}</p>
        <p>{about.paragraphs[2]}</p>
        <a class="round-link" href="/about">
          <span>Read the longer version</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
      <a class="personal-note" href="https://blumblumblum.com" target="_blank" rel="noopener">
        <Image
          class="personal-note-image"
          src={blumCollage}
          alt=""
          widths={[320, 480, 640, 960, 1280]}
          sizes="(max-width: 52rem) calc(100vw - 2rem), 58vw"
          loading="lazy"
        />
        <span class="note-arrow" aria-hidden="true">↗</span>
        <span class="note-plaque">
          <Image class="note-logo" src={blumTagLogo} alt="" width={300} loading="lazy" />
        </span>
        <span class="visually-hidden">Visit blumblumblum (opens in a new tab)</span>
      </a>
    </section>
  </main>
</Base>

<style>
  .work-section,
  .more-section,
  .about-preview {
    padding-block: clamp(var(--space-24), 11vw, var(--space-32));
  }

  .work-section {
    scroll-margin-top: var(--space-8);
  }

  .section-intro {
    display: grid;
    grid-template-columns: minmax(8rem, 0.32fr) minmax(0, 1fr);
    gap: var(--space-8);
    align-items: start;
    margin-bottom: var(--space-16);
  }

  .section-intro.compact {
    margin-bottom: var(--space-12);
  }

  .section-kicker {
    padding-top: 0.55rem;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: lowercase;
  }

  .section-intro > div {
    grid-column: 2;
    display: grid;
    gap: var(--space-4);
  }

  .section-intro h2,
  .about-copy h2 {
    max-width: 21ch;
    font-size: clamp(2rem, 4.6vw, 4rem);
    line-height: 1.02;
    letter-spacing: -0.045em;
  }

  #more-heading {
    font-family: var(--font-personality);
    font-weight: 600;
  }

  .section-intro > div > p {
    max-width: 54ch;
    color: var(--ink-muted);
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .more-section {
    border-top: 1px solid var(--hairline);
  }

  .about-preview {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: var(--space-8);
    align-items: start;
    border-top: 1px solid var(--hairline);
  }

  .about-copy {
    grid-column: 1 / span 5;
    display: grid;
    gap: var(--space-5);
    max-width: 40rem;
  }

  .about-copy > p {
    max-width: 53ch;
    color: var(--ink-muted);
    font-size: 1.02rem;
  }

  .round-link {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-4);
    padding: 0.72rem 1rem;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    background: var(--paper-raised);
    font-size: 0.86rem;
    font-weight: 500;
    transition: border-color var(--duration-default) var(--ease), transform var(--duration-default) var(--ease);
  }

  .personal-note {
    position: relative;
    grid-column: 6 / -1;
    display: grid;
    min-height: clamp(30rem, 42vw, 38rem);
    overflow: hidden;
    border-radius: var(--radius-xl);
    background: var(--paper-raised);
    color: var(--heading);
    isolation: isolate;
    transition: transform var(--duration-default) var(--ease);
  }

  .personal-note :global(.personal-note-image) {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 42%;
    transition: transform var(--duration-slow) var(--ease);
  }

  .note-plaque {
    position: absolute;
    z-index: 2;
    top: 50%;
    left: 50%;
    display: grid;
    width: min(72%, 26rem);
    min-height: clamp(8rem, 16vw, 11rem);
    place-items: center;
    padding: var(--space-6);
    border: 1px solid color-mix(in oklab, var(--paper-raised) 78%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in oklab, var(--paper-raised) 90%, transparent);
    box-shadow: var(--shadow-lifted);
    backdrop-filter: blur(var(--space-4));
    transform: translate(-50%, -50%);
  }

  .note-plaque :global(.note-logo) {
    display: block;
    width: min(100%, 13rem);
    height: auto;
    transform-origin: 48% 54%;
  }

  .note-arrow {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    z-index: 2;
    display: grid;
    width: var(--space-8);
    aspect-ratio: 1;
    place-items: center;
    border: 1px solid color-mix(in oklab, var(--heading) 18%, transparent);
    border-radius: 50%;
    background: color-mix(in oklab, var(--paper-raised) 90%, transparent);
    box-shadow: var(--shadow-small);
    backdrop-filter: blur(var(--space-2));
  }

  html.pointer-moved .round-link:hover {
    border-color: var(--ink-muted);
    transform: translateY(-2px);
  }

  html.pointer-moved .personal-note:hover {
    transform: translateY(-3px);
  }

  html.pointer-moved .personal-note:hover :global(.personal-note-image) {
    transform: scale(1.015);
  }

  html.pointer-moved .personal-note:hover .note-plaque :global(.note-logo) {
    animation: blum-mark-hop var(--duration-slow) var(--ease) 1;
  }

  @keyframes blum-mark-hop {
    0%,
    100% {
      transform: translateY(0) rotate(0deg) scale(1);
    }

    42% {
      transform: translateY(-4px) rotate(-1.5deg) scale(1.02);
    }

    72% {
      transform: translateY(1px) rotate(0.5deg) scale(0.995);
    }
  }

  @media (max-width: 52rem) {
    .section-intro,
    .about-preview {
      grid-template-columns: 1fr;
    }

    .section-intro {
      gap: var(--space-4);
    }

    .section-intro > div {
      grid-column: 1;
    }

    .about-preview {
      gap: var(--space-8);
    }

    .about-copy,
    .personal-note {
      grid-column: 1;
    }

    .personal-note {
      min-height: min(38rem, 118vw);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .round-link,
    .personal-note,
    .personal-note :global(.personal-note-image) {
      transition: none;
    }

    html.pointer-moved .personal-note:hover :global(.personal-note-image) {
      transform: none;
    }

    html.pointer-moved .personal-note:hover .note-plaque :global(.note-logo) {
      animation: none;
    }
  }
</style>
